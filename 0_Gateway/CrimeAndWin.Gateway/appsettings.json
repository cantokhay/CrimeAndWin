{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/gateway-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "JwtSettings": {
    "Issuer": "CrimeAndWin.Identity",
    "Audience": "CrimeAndWin.Gateway",
    "SecretKey": "CHANGE_ME_USE_ENV_VAR_IN_PROD_32CHARS_MIN"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-public-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/identity/{**catch-all}" }
      },
      "playerprofile-route": {
        "ClusterId": "playerprofile-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/playerprofile/{**catch-all}" }
      },
      "gameworld-route": {
        "ClusterId": "gameworld-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/gameworld/{**catch-all}" }
      },
      "action-route": {
        "ClusterId": "action-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/action/{**catch-all}" }
      },
      "economy-route": {
        "ClusterId": "economy-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/economy/{**catch-all}" }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/inventory/{**catch-all}" }
      },
      "leadership-route": {
        "ClusterId": "leadership-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/leadership/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/notification/{**catch-all}" }
      },
      "moderation-route": {
        "ClusterId": "moderation-cluster",
        "AuthorizationPolicy": "RequireAuthPolicy",
        "Match": { "Path": "/api/moderation/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster":      { "Destinations": { "primary": { "Address": "http://localhost:6001/" } } },
      "playerprofile-cluster": { "Destinations": { "primary": { "Address": "http://localhost:6002/" } } },
      "gameworld-cluster":     { "Destinations": { "primary": { "Address": "http://localhost:6003/" } } },
      "action-cluster":        { "Destinations": { "primary": { "Address": "http://localhost:6004/" } } },
      "economy-cluster":       { "Destinations": { "primary": { "Address": "http://localhost:6005/" } } },
      "inventory-cluster":     { "Destinations": { "primary": { "Address": "http://localhost:6006/" } } },
      "leadership-cluster":    { "Destinations": { "primary": { "Address": "http://localhost:6007/" } } },
      "notification-cluster":  { "Destinations": { "primary": { "Address": "http://localhost:6008/" } } },
      "moderation-cluster":    { "Destinations": { "primary": { "Address": "http://localhost:6009/" } } }
    }
  }
}
