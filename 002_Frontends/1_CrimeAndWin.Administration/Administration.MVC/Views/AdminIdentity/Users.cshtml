@model List<ResultAppUserVM>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kullanici Yonetimi";
}

<!--begin::Toolbar-->
<div class="toolbar py-5 py-lg-15" id="kt_toolbar">
    <div id="kt_toolbar_container" class="container-xxl d-flex flex-stack flex-wrap">
        <div class="page-title d-flex flex-column me-3">
            <h1 class="d-flex text-white fw-bold my-1 fs-3">Kullanici Hesaplari</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                <li class="breadcrumb-item text-white opacity-75">Admin</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75 text-hover-primary">Kimlik Yonetimi</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75">Kullanicilar</li>
            </ul>
        </div>
    </div>
</div>
<!--end::Toolbar-->

<div class="card card-flush shadow-sm border-0 mb-5 mb-xl-8">
    <div class="card-header pt-7">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark fs-3">Kullanici Listesi</span>
            <span class="text-gray-400 mt-1 fw-semibold fs-7">Sistemdeki tum kayitli personeller ve oyuncular</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateUser" asp-controller="AdminIdentity" class="btn btn-sm btn-primary fw-bold">
                <i class="ki-duotone ki-plus fs-2 me-1"></i> Yeni Kullanici
            </a>
        </div>
    </div>

    <div class="card-body pt-5">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_users_table">
                <thead>
                    <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-200px">Kullanici Bilgisi</th>
                        <th class="min-w-150px">Iletisim</th>
                        <th class="min-w-120px text-center">Durum</th>
                        <th class="min-w-130px">Guvenlik Bilgisi</th>
                        <th class="min-w-120px text-end">Kayit Tarihi</th>
                        <th class="text-end min-w-100px">Islemler</th>
                    </tr>
                </thead>
                <tbody class="fw-semibold text-gray-600">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-45px me-3">
                                        <div class="symbol-label bg-light-primary text-primary fw-bold fs-4">
                                            @user.UserName.Substring(0,1).ToUpper()
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <span class="text-dark fw-bold text-hover-primary fs-6">@user.UserName</span>
                                        <span class="text-muted fw-semibold d-block fs-8">UUID: #@(user.Id.ToString().Substring(0, 8))</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold mr-2 fs-6">@user.Email</span>
                                    <span class="text-muted fw-bold fs-8">@user.PhoneNumber</span>
                                </div>
                            </td>
                            <td class="text-center">
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge badge-light-success border border-success border-dashed fw-bold px-3 py-2">AKTIF</span>
                                }
                                else
                                {
                                    <span class="badge badge-light-warning border border-warning border-dashed fw-bold px-3 py-2">ONAY BEKLIYOR</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    @if (user.LockoutEnabled)
                                    {
                                        <span class="text-danger fw-bold fs-8 d-flex align-items-center">
                                            <i class="ki-duotone ki-lock fs-9 text-danger me-1"></i> Kilitlenmis
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold fs-8 d-flex align-items-center">
                                            <i class="ki-duotone ki-lock-open fs-9 text-success me-1"></i> Guvenli
                                        </span>
                                    }
                                    <span class="text-muted fs-9">Hata Sayısı: @user.AccessFailedCount</span>
                                </div>
                            </td>
                            <td class="text-end text-muted fs-7">
                                @user.CreatedAtUtc.ToString("dd MMM yyyy") <br/>
                                <span class="fs-9 opacity-50">@user.CreatedAtUtc.ToString("HH:mm")</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="EditUser" asp-controller="AdminIdentity" asp-route-id="@user.Id" 
                                   class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                    <i class="ki-duotone ki-pencil fs-2"></i>
                                </a>
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm js-delete-user-btn" 
                                        data-id="@user.Id" data-name="@user.UserName">
                                    <i class="ki-duotone ki-trash fs-2"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-user-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');

            Swal.fire({
                title: 'Hesabı Sil?',
                text: `${name} adlı kullanıcıyı sistemden tamamen kaldırmak istiyor musunuz?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgec',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteUser", "AdminIdentity")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Silindi!', 'Kullanıcı kaydı başarıyla silindi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', res.message || 'Bir sorun olustu.', 'error');
                            }
                        }
                    });
                }
            });
        });
    </script>
}
