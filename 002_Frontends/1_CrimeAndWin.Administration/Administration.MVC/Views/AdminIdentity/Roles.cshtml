@model List<ResultRoleVM>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Rol Yonetimi";
}

<!--begin::Toolbar-->
<div class="toolbar py-5 py-lg-15" id="kt_toolbar">
    <div id="kt_toolbar_container" class="container-xxl d-flex flex-stack flex-wrap">
        <div class="page-title d-flex flex-column me-3">
            <h1 class="d-flex text-white fw-bold my-1 fs-3">Yetki Gruplari</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                <li class="breadcrumb-item text-white opacity-75">Admin</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75 text-hover-primary">Kimlik Yonetimi</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75">Roller</li>
            </ul>
        </div>
    </div>
</div>
<!--end::Toolbar-->

<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <div class="col-md-3">
        <div class="card card-flush h-md-100 shadow-sm border-0 border-start border-warning border-4">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@Model.Count</span>
                    <span class="text-gray-400 pt-1 fw-semibold fs-6">Sistemdeki Toplam Rol</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5">
                <i class="ki-duotone ki-shield-search fs-3x text-warning"></i>
            </div>
        </div>
    </div>
</div>

<div class="card card-flush shadow-sm border-0">
    <div class="card-header pt-7">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark fs-3">Sistem Rolleri</span>
            <span class="text-gray-400 mt-1 fw-semibold fs-7">Kullanici yetkilendirme ve erisim gruplari</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateRole" asp-controller="AdminIdentity" class="btn btn-sm btn-primary fw-bold">
                <i class="ki-duotone ki-plus fs-2 me-1"></i> Yeni Rol
            </a>
        </div>
    </div>

    <div class="card-body pt-5">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_roles_table">
                <thead>
                    <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-200px">Rol Adi</th>
                        <th class="min-w-300px">Aciklama</th>
                        <th class="min-w-150px text-end">Olusturma Tarihi</th>
                        <th class="text-end min-w-100px">Islemler</th>
                    </tr>
                </thead>
                <tbody class="fw-semibold text-gray-600">
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px me-3">
                                        <div class="symbol-label bg-light-info text-info fw-bold fs-5">
                                            @role.Name[0].ToString().ToUpper()
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <span class="text-dark fw-bold text-hover-primary fs-6">@role.Name</span>
                                        <span class="text-muted fw-semibold d-block fs-9">UUID: #@(role.Id.ToString().Substring(0, 8))</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-gray-600 fw-bold fs-7">
                                    @(string.IsNullOrEmpty(role.Description) ? "Aciklama belirtilmemis" : role.Description)
                                </span>
                            </td>
                            <td class="text-end text-muted fs-7">
                                @role.CreatedAtUtc.ToString("dd MMM yyyy") <br/>
                                <span class="fs-9 opacity-50">@role.CreatedAtUtc.ToString("HH:mm")</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="EditRole" asp-controller="AdminIdentity" asp-route-id="@role.Id" 
                                   class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                    <i class="ki-duotone ki-pencil fs-2"></i>
                                </a>
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm js-delete-role-btn" 
                                        data-id="@role.Id" data-name="@role.Name">
                                    <i class="ki-duotone ki-trash fs-2"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-role-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');

            Swal.fire({
                title: 'Rolü Sil?',
                text: `${name} rolünü silmek istediginizden emin misiniz? Bu role sahip kullanicilar yetkilerini kaybedebilir!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgec',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteRole", "AdminIdentity")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Silindi!', 'Rol basariyla silindi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', res.message || 'Bir sorun olustu.', 'error');
                            }
                        }
                    });
                }
            });
        });
    </script>
}
