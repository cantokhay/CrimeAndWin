@model List<ResultRoleVM>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Rol Yönetimi";
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-primary">
                            <i class="ki-duotone ki-shield-search fs-2x text-primary"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Toplam Rol</span>
                        <span class="fs-2 fw-bold mb-0">@Model.Count</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Sistem Rolleri</span>
            <span class="text-muted mt-1 fw-bold fs-7">Kullanıcı yetkilendirme grupları</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateRole" asp-controller="AdminIdentity" class="btn btn-sm btn-primary">
                <i class="ki-duotone ki-plus fs-2"></i> Yeni Rol Oluştur
            </a>
        </div>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                <thead>
                    <tr class="fw-bolder text-muted">
                        <th class="min-w-150px">Rol Adı</th>
                        <th>Açıklama</th>
                        <th>Oluşturma Tarihi</th>
                        <th class="min-w-100px text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-35px me-3">
                                        <span class="symbol-label bg-light-info text-info fw-bold">@item.Name[0]</span>
                                    </div>
                                    <span class="text-dark fw-bolder text-hover-primary fs-6">@item.Name</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted fw-bold fs-7">@(string.IsNullOrEmpty(item.Description) ? "Açıklama girilmemiş" : item.Description)</span>
                            </td>
                            <td>
                                <span class="text-muted fw-bold d-block fs-7">@item.CreatedAtUtc.ToString("g")</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="EditRole" asp-controller="AdminIdentity" asp-route-id="@item.Id" 
                                   class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                    <i class="ki-duotone ki-pencil fs-3"></i>
                                </a>
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm js-delete-role-btn" 
                                        data-id="@item.Id" data-name="@item.Name">
                                    <i class="ki-duotone ki-trash fs-3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-role-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');

            Swal.fire({
                title: 'Rolü Sil?',
                text: `${name} rolünü silmek istediğinize emin misiniz? Bu role sahip kullanıcılar yetkilerini kaybedebilir!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/AdminIdentity/DeleteRole',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Silindi!', 'Rol başarıyla silindi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', 'Silme işlemi sırasında bir hata oluştu.', 'error');
                            }
                        }
                    });
                }
            });
        });
    </script>
}