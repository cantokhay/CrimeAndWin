@model List<ResultAppUserVM>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Onay Bekleyen Kullanicilar";
}

<!--begin::Toolbar-->
<div class="toolbar py-5 py-lg-15" id="kt_toolbar">
    <div id="kt_toolbar_container" class="container-xxl d-flex flex-stack flex-wrap">
        <div class="page-title d-flex flex-column me-3">
            <h1 class="d-flex text-white fw-bold my-1 fs-3">Hesap Onay Kuyrugu</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                <li class="breadcrumb-item text-white opacity-75">Admin</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75 text-hover-primary">Kimlik Yonetimi</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75">Onay Bekleyenler</li>
            </ul>
        </div>
    </div>
</div>
<!--end::Toolbar-->

<div class="card card-flush shadow-sm border-0 mb-5 mb-xl-8">
    <div class="card-header pt-7">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark fs-3">Onay Bekleyen Kullanicilar</span>
            <span class="text-gray-400 mt-1 fw-semibold fs-7">@Model.Count kullanici hesabinin aktifleştirilmesi gerekiyor</span>
        </h3>
        <div class="card-toolbar">
            @if (Model.Any())
            {
                <button type="button" class="btn btn-sm btn-primary fw-bold js-approve-all-users">
                    <i class="ki-duotone ki-double-check fs-2 me-1"></i> Tümünü Onayla
                </button>
            }
        </div>
    </div>

    <div class="card-body pt-5">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_approvals_table">
                <thead>
                    <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-250px">Kullanici Bilgisi</th>
                        <th class="min-w-150px">Basvuru Tarihi</th>
                        <th class="text-end min-w-100px">Islemler</th>
                    </tr>
                </thead>
                <tbody class="fw-semibold text-gray-600">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px me-3">
                                        <div class="symbol-label bg-light-warning text-warning fw-bold fs-5">
                                            @user.UserName.Substring(0,1).ToUpper()
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <span class="text-dark fw-bold text-hover-primary fs-6">@user.UserName</span>
                                        <span class="text-muted fw-semibold d-block fs-8">@user.Email</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold fs-7">@user.CreatedAtUtc.ToString("dd MMM yyyy")</span>
                                    <span class="text-muted fs-8">@user.CreatedAtUtc.ToString("HH:mm")</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-success btn-sm btn-approve-user" 
                                        data-id="@user.Id" data-username="@user.UserName">
                                    <i class="ki-duotone ki-check fs-2"></i>
                                </button>
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm">
                                    <i class="ki-duotone ki-cross fs-2"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-10">
                                <div class="d-flex flex-column flex-center">
                                    <i class="ki-duotone ki-shield-search fs-5x text-gray-200 mb-3"></i>
                                    <span class="text-gray-400 fw-semibold fs-5">Onay bekleyen kullanici bulunmamaktadir.</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.btn-approve-user', function() {
            const userId = $(this).data('id');
            const username = $(this).data('username');

            Swal.fire({
                title: 'Onayla?',
                text: `${username} hesabini aktifestirmek istiyor musunuz?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Evet, Onayla!',
                cancelButtonText: 'Vazgec',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-primary",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("ApproveUser", "AdminIdentity")',
                        type: 'POST',
                        data: {
                            id: userId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Basarli!', 'Hesap onaylandi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', 'Bir sorun olustu.', 'error');
                            }
                        }
                    });
                }
            });
        });

        $(document).on('click', '.js-approve-all-users', function() {
            Swal.fire({
                title: 'Hepsini Onayla?',
                text: 'Tum bekleyen başvurulari onaylamak istediginize emin misiniz?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Hepsini Onayla!',
                cancelButtonText: 'Vazgec',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-success",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("ApproveAllPendingUsers", "AdminIdentity")',
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Basarli!', 'Tum liste onaylandi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', 'Islem sirasinda bir hata olustu.', 'error');
                            }
                        }
                    });
                }
            });
        });
    </script>
}
