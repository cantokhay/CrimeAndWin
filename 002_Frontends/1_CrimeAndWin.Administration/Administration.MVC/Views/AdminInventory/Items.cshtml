@model List<ResultItemVM>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Eşya Kataloğu";
    var totalItems = Model.Count;
    var totalQty = Model.Sum(x => x.Quantity);
}

@Html.AntiForgeryToken()

<div class="row g-5 g-xl-10 mb-8 mt-5">
    <div class="col-md-3">
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-primary text-primary">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@totalItems</span>
                        <span class="badge badge-light-primary border border-primary border-dashed fs-7 fw-bold px-3 py-1">Tür</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Tanımlı Eşya Şablonu</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5">
                <i class="ki-duotone ki-abstract-26 fs-3x"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-info text-info">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@totalQty</span>
                        <span class="badge badge-light-info border border-info border-dashed fs-7 fw-bold px-3 py-1">Adet</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Sistemdeki Toplam Stok</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5">
                <i class="ki-duotone ki-delivery-3 fs-3x"></i>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8 shadow-sm">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Eşya Referans Listesi</span>
            <span class="text-muted mt-1 fw-bold fs-7">Sistemde tanımlı tüm eşya templateleri ve temel özellikleri</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateItem" class="btn btn-sm btn-primary">
                <i class="ki-duotone ki-plus fs-2 me-1"></i> Yeni Eşya Tanımla
            </a>
        </div>
    </div>

    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-4">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th class="ps-4 rounded-start min-w-200px">Eşya Adı / Tanımı</th>
                        <th>Envanter Grubu</th>
                        <th class="text-center">Teknik Özellikler</th>
                        <th class="text-center">Ekonomik Değer</th>
                        <th class="text-center">Mevcut Stok</th>
                        <th class="min-w-100px text-end pe-4 rounded-end">Yönetim</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-45px me-3">
                                        <span class="symbol-label bg-light-primary text-primary fw-bold fs-4">@item.Name[0]</span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bold text-hover-primary mb-1 fs-6">@item.Name</span>
                                        <span class="text-muted fw-semi-bold d-block fs-8">UUID: @item.Id.ToString().Substring(0, 8)</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold fs-7">@(item.InventoryDisplay ?? "Sistem")</span>
                                    <span class="text-muted fs-8">ID: @item.InventoryId.ToString().Substring(0, 8)</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <span class="badge badge-light-danger fs-8 fw-bold" data-bs-toggle="tooltip" title="Hasar Gücü">
                                        <i class="ki-duotone ki-shield-cross fs-9 text-danger me-1"></i> @item.Damage
                                    </span>
                                    <span class="badge badge-light-success fs-8 fw-bold" data-bs-toggle="tooltip" title="Savunma Puanı">
                                        <i class="ki-duotone ki-shield-tick fs-9 text-success me-1"></i> @item.Defense
                                    </span>
                                    <span class="badge badge-light-primary fs-8 fw-bold" data-bs-toggle="tooltip" title="Ekstra Güç">
                                        <i class="ki-duotone ki-flash-circle fs-9 text-primary me-1"></i> @item.Power
                                    </span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="text-dark fw-bold fs-7">@item.Amount.ToString("N0")</span>
                                <span class="text-muted fs-8 d-block">@item.CurrencyText</span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-light-info border border-info border-dashed fw-bold px-4 py-2">@item.Quantity Adet</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="EditItem" asp-route-id="@item.Id" class="btn btn-icon btn-light-primary btn-active-primary btn-sm me-2 shadow-sm">
                                    <i class="ki-duotone ki-pencil fs-3"></i>
                                </a>
                                <button type="button" class="btn btn-icon btn-light-danger btn-active-danger btn-sm shadow-sm js-delete-item-btn" 
                                        data-id="@item.Id" data-name="@item.Name">
                                    <i class="ki-duotone ki-trash fs-3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-item-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');
            const token = $('input[name="__RequestVerificationToken"]').val();

            Swal.fire({
                title: 'Eşya Silinsin mi?',
                text: `"${name}" eşya tanımı sistemden tamamen kaldırılacak. Bu envanterlerdeki itemleri de etkileyebilir.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                },
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return $.ajax({
                        url: '@Url.Action("DeleteItem", "AdminInventory")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: token
                        }
                    }).then(response => {
                        if (!response.success) {
                            throw new Error(response.message || 'Silme işlemi başarısız');
                        }
                        return response;
                    }).catch(error => {
                        Swal.showValidationMessage(`Hata: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Silindi!',
                        text: 'Eşya tanımı başarıyla kaldırıldı.',
                        icon: 'success',
                        customClass: { confirmButton: 'btn btn-primary' }
                    }).then(() => location.reload());
                }
            });
        });

        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        });
    </script>
}