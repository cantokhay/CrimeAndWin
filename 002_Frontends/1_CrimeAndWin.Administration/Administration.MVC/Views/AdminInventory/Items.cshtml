@model List<ResultItemVM>
@{
    ViewData["Title"] = "Esya Referans Yonetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!--begin::Toolbar-->
<div class="toolbar py-5 py-lg-15" id="kt_toolbar">
    <div id="kt_toolbar_container" class="container-xxl d-flex flex-stack flex-wrap">
        <div class="page-title d-flex flex-column me-3">
            <h1 class="d-flex text-white fw-bold my-1 fs-3">Esya Kutuphanesi</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                <li class="breadcrumb-item text-white opacity-75">Oyun Yonetimi</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75 text-hover-primary">Envanter</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75">Referans Esyalar</li>
            </ul>
        </div>
    </div>
</div>
<!--end::Toolbar-->

<div class="card card-flush shadow-sm border-0 mb-5 mb-xl-8">
    <div class="card-header pt-7">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark fs-3">Esya Katalogu</span>
            <span class="text-gray-400 mt-1 fw-semibold fs-7">Sistemdeki tum esya sablonlari ve teknik verileri</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateItem" class="btn btn-sm btn-primary fw-bold">
                <i class="ki-duotone ki-plus fs-2 me-1"></i> Yeni Esya Tanımla
            </a>
        </div>
    </div>

    <div class="card-body pt-5">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_items_table">
                <thead>
                    <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-200px">Esya Bilgisi</th>
                        <th class="min-w-100px text-center">Nadirlik</th>
                        <th class="min-w-150px text-center">Teknik Limitler</th>
                        <th class="min-w-100px text-end">Birim Fiyat</th>
                        <th class="min-w-120px text-center">Stok Durumu</th>
                        <th class="text-end min-w-100px">Islemler</th>
                    </tr>
                </thead>
                <tbody class="fw-semibold text-gray-600">
                    @foreach (var item in Model)
                    {
                        // Rarity Logic (Mocked for UI standardization)
                        var rarityClass = (item.Defense > 50 || item.Damage > 50) ? "badge-light-warning" : (item.Damage > 20 ? "badge-light-primary" : "badge-light-secondary");
                        var rarityText = (item.Defense > 50 || item.Damage > 50) ? "Legendary" : (item.Damage > 20 ? "Rare" : "Common");

                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-45px me-3">
                                        <div class="symbol-label bg-light-warning text-warning fs-3 fw-bold">
                                            @item.Name.Substring(0,1)
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <span class="text-dark fw-bold text-hover-primary fs-6">@item.Name</span>
                                        <span class="text-muted fw-semibold d-block fs-8">Ref: #@(item.Id.ToString().Substring(0, 8))</span>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge @rarityClass fw-bold px-4 py-2">@rarityText</span>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-1">
                                    <span class="badge badge-outline badge-danger fs-8" data-bs-toggle="tooltip" title="Hasar">@item.Damage DMG</span>
                                    <span class="badge badge-outline badge-success fs-8" data-bs-toggle="tooltip" title="Savunma">@item.Defense DEF</span>
                                    <span class="badge badge-outline badge-primary fs-8" data-bs-toggle="tooltip" title="Guc">@item.Power PWR</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <span class="text-dark fw-bold">@item.Amount.ToString("N0")</span>
                                <span class="text-muted fs-8 d-block">@item.CurrencyText</span>
                            </td>
                            <td class="text-center">
                                <div class="badge badge-light-info fw-bold">@item.Quantity Adet</div>
                            </td>
                            <td class="text-end">
                                <a asp-action="EditItem" asp-route-id="@item.Id" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                    <i class="ki-duotone ki-pencil fs-2"></i>
                                </a>
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm js-delete-item-btn" 
                                        data-id="@item.Id" data-name="@item.Name">
                                    <i class="ki-duotone ki-trash fs-2"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-item-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');
            const token = $('input[name="__RequestVerificationToken"]').val();

            Swal.fire({
                title: 'Esyayı Sil?',
                text: `${name} katalogdan kaldırılsın mı?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgec',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteItem", "AdminInventory")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: token },
                        success: function(res) {
                            if(res.success) {
                                Swal.fire("Basarılı", "Esya silindi.", "success").then(() => location.reload());
                            } else {
                                Swal.fire("Hata", res.message, "error");
                            }
                        }
                    });
                }
            });
        });
    </script>
}
