@model CreateItemVM

@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Yeni Item</h3>
        <a asp-action="Items" asp-controller="AdminInventory" class="btn btn-sm btn-light">Listeye Dön</a>
    </div>

    <div class="card-body">
        <form asp-action="CreateItem" asp-controller="AdminInventory" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-12">
                    <label class="form-label">Inventory</label>
                    <select asp-for="InventoryId" asp-items="Model.InventoryOptions" class="form-select"></select>
                    <span asp-validation-for="InventoryId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Quantity</label>
                    <input asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Damage</label>
                    <input asp-for="Damage" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Defense</label>
                    <input asp-for="Defense" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Power</label>
                    <input asp-for="Power" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Amount</label>
                    <input asp-for="Amount" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Currency</label>
                    <select asp-for="Currency" asp-items="Model.CurrencyOptions" class="form-select"></select>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Items" asp-controller="AdminInventory" class="btn btn-light ms-2">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}