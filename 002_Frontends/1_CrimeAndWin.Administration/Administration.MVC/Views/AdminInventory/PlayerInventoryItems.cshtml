@model Administration.MVC.ViewModels.InventoryVMs.PlayerInventoryItemsVMs.PlayerInventoryItemsVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Envanter Tarayıcı";
}

@Html.AntiForgeryToken()

<div class="card mb-5">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Envanter Tarayıcı</span>
            <span class="text-muted mt-1 fw-bold fs-7">Oyuncu ve envanter seçerek eşyaları yönetin</span>
        </h3>
    </div>

    <div class="card-body">
        <div class="row g-5">
            <div class="col-md-6">
                <label class="form-label fw-bold text-gray-700">Oyuncu Seçimi</label>
                <select id="playerSelect" class="form-select form-select-solid" data-control="select2" data-placeholder="Oyuncu ara veya seç...">
                    <option value="">-- Oyuncu seçin --</option>
                    @foreach (var p in Model.PlayerOptions)
                    {
                        <option value="@p.Value">@p.Text</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-bold text-gray-700">Envanter Seçimi</label>
                <select id="inventorySelect" class="form-select form-select-solid" disabled>
                    <option value="">-- Önce oyuncu seçin --</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Eşyalar</span>
            <span id="itemsCountText" class="text-muted mt-1 fw-bold fs-7">0 kayıt bulundu</span>
        </h3>

        <div class="card-toolbar">
            <a id="btnCreateItem"
               class="btn btn-sm btn-primary disabled"
               href="javascript:void(0)"
               title="Önce envanter seçmelisiniz">
                <i class="ki-duotone ki-plus fs-2 me-1"></i> Yeni Eşya Ekle
            </a>
        </div>
    </div>

    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th class="ps-4 rounded-start">Eşya</th>
                        <th>Miktar</th>
                        <th>İstatistikler</th>
                        <th>Değer</th>
                        <th>Eklenme</th>
                        <th class="min-w-100px text-end pe-4 rounded-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="itemsTbody">
                    <tr>
                        <td colspan="6" class="text-center text-muted py-10">
                            <div class="d-flex flex-column align-items-center">
                                <i class="ki-duotone ki-search-list fs-3hx text-gray-400 mb-3"></i>
                                <span>Lütfen bir oyuncu ve ardından envanter seçin.</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const playerSelect = document.getElementById('playerSelect');
            const inventorySelect = document.getElementById('inventorySelect');
            const itemsTbody = document.getElementById('itemsTbody');
            const itemsCountText = document.getElementById('itemsCountText');
            const btnCreateItem = document.getElementById('btnCreateItem');

            function setInfoRow(message) {
                itemsTbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center text-muted py-10">${message}</td>
                    </tr>`;
                itemsCountText.textContent = `0 kayıt bulundu`;
            }

            function setErrorRow(message) {
                itemsTbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center text-danger py-10">${message}</td>
                    </tr>`;
                itemsCountText.textContent = `0 kayıt bulundu`;
            }

            function escapeHtml(str) {
                if (str === null || str === undefined) return '';
                return String(str)
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#039;');
            }

            function currencyToText(currency) {
                if (currency === null || currency === undefined) return '';
                if (typeof currency === 'number') {
                    switch (currency) {
                        case 1: return 'Gold';
                        case 2: return 'Gem';
                        case 3: return 'Credit';
                        default: return String(currency);
                    }
                }
                return String(currency);
            }

            function formatDate(dateValue) {
                if (!dateValue) return '';
                const d = new Date(dateValue);
                if (isNaN(d.getTime())) return '';
                return d.toLocaleString();
            }

            async function safeFetchJson(url) {
                const res = await fetch(url);
                if (!res.ok) throw new Error(`Sunucu hatası: ${res.status}`);
                return await res.json();
            }

            function resetCreateButton() {
                btnCreateItem.classList.add('disabled');
                btnCreateItem.href = 'javascript:void(0)';
                btnCreateItem.setAttribute('title', 'Önce envanter seçmelisiniz');
            }

            function enableCreateButton(inventoryId) {
                btnCreateItem.classList.remove('disabled');
                btnCreateItem.removeAttribute('title');
                btnCreateItem.href = `@Url.Action("CreateItem", "AdminInventory")?inventoryId=${encodeURIComponent(inventoryId)}`;
            }

            function wireDeleteHandlers() {
                document.querySelectorAll('.js-delete-item-btn').forEach(btn => {
                    btn.addEventListener('click', async function (e) {
                        const id = this.dataset.id;
                        const name = this.dataset.name;

                        Swal.fire({
                            title: 'Eşyayı Sil?',
                            text: `${name} eşyasını silmek istediğinize emin misiniz?`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Evet, Sil!',
                            cancelButtonText: 'Vazgeç',
                            customClass: {
                                confirmButton: "btn btn-danger",
                                cancelButton: "btn btn-active-light"
                            }
                        }).then(async (result) => {
                            if (result.isConfirmed) {
                                try {
                                    const formData = new FormData();
                                    formData.append('id', id);
                                    formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                                    const res = await fetch(`@Url.Action("DeleteItem", "AdminInventory")`, {
                                        method: 'POST',
                                        body: formData
                                    });

                                    const json = await res.json();
                                    if (json.success) {
                                        Swal.fire({
                                            icon: 'success',
                                            title: 'Başarılı!',
                                            text: 'Eşya envanterden silindi.',
                                            timer: 1500,
                                            showConfirmButton: false
                                        }).then(() => {
                                            inventorySelect.dispatchEvent(new Event('change'));
                                        });
                                    } else {
                                        Swal.fire('Hata!', 'Silme işlemi başarısız oldu.', 'error');
                                    }
                                } catch (err) {
                                    Swal.fire('Hata!', 'Sistemde bir hata oluştu.', 'error');
                                }
                            }
                        });
                    });
                });
            }

            playerSelect.addEventListener('change', async function () {
                const playerId = this.value;
                resetCreateButton();
                inventorySelect.disabled = true;
                inventorySelect.innerHTML = `<option value="">-- Envanterler yükleniyor... --</option>`;
                setInfoRow('Oyuncu seçildi, envanter yükleniyor...');

                if (!playerId) {
                    inventorySelect.innerHTML = `<option value="">-- Önce oyuncu seçin --</option>`;
                    setInfoRow('Lütfen bir oyuncu seçin.');
                    return;
                }

                try {
                    const url = `@Url.Action("GetInventoriesByPlayer", "AdminInventory")?playerId=${encodeURIComponent(playerId)}`;
                    const list = await safeFetchJson(url);

                    if (!Array.isArray(list) || list.length === 0) {
                        inventorySelect.innerHTML = `<option value="">-- Envanter bulunamadı --</option>`;
                        setInfoRow('Bu oyuncu için tanımlı bir envanter bulunamadı.');
                        return;
                    }

                    inventorySelect.innerHTML =
                        `<option value="">-- Envanter seçin --</option>` +
                        list.map(x => `<option value="${escapeHtml(x.id)}">${escapeHtml(x.text)}</option>`).join('');

                    inventorySelect.disabled = false;
                    setInfoRow('Envanter seçince eşyalar listelenecek.');
                } catch (e) {
                    inventorySelect.innerHTML = `<option value="">-- Hata oluştu --</option>`;
                    setErrorRow(`Hata: ${escapeHtml(e.message)}`);
                }
            });

            inventorySelect.addEventListener('change', async function () {
                const inventoryId = this.value;
                resetCreateButton();

                if (!inventoryId) {
                    setInfoRow('Lütfen bir envanter seçin.');
                    return;
                }

                enableCreateButton(inventoryId);
                setInfoRow('Eşyalar getiriliyor...');

                try {
                    const url = `@Url.Action("GetItemsByInventory", "AdminInventory")?inventoryId=${encodeURIComponent(inventoryId)}`;
                    const items = await safeFetchJson(url);

                    if (!Array.isArray(items) || items.length === 0) {
                        itemsTbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-10">Envanter boş.</td></tr>`;
                        itemsCountText.textContent = `0 kayıt bulundu`;
                        return;
                    }

                    itemsCountText.textContent = `${items.length} kayıt bulundu`;

                    itemsTbody.innerHTML = items.map(it => {
                        const stats = `<span class="text-muted fs-8">S: <span class="text-danger fw-bold">${escapeHtml(it.damage)}</span> / Sav: <span class="text-success fw-bold">${escapeHtml(it.defense)}</span> / Güç: <span class="text-primary fw-bold">${escapeHtml(it.power)}</span></span>`;
                        const value = `<span class="text-dark fw-bold fs-7">${escapeHtml(it.amount)} <small class="text-muted">(${escapeHtml(currencyToText(it.currencyText ?? it.currency))})</small></span>`;
                        const editUrl = `@Url.Action("EditItem", "AdminInventory")/${encodeURIComponent(it.id)}`;

                        return `
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="symbol symbol-30px me-3">
                                            <span class="symbol-label bg-light-primary text-primary fw-bold fs-8">${it.name[0]}</span>
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="text-dark fw-bold mb-1 fs-6">${escapeHtml(it.name)}</span>
                                            <span class="text-muted fs-9">${escapeHtml(it.id.substring(0,8))}</span>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge badge-light-info fw-bold">${escapeHtml(it.quantity)}</span></td>
                                <td>${stats}</td>
                                <td>${value}</td>
                                <td><span class="text-muted fw-bold fs-7">${escapeHtml(formatDate(it.createdAtUtc))}</span></td>
                                <td class="text-end pe-4">
                                    <a href="${editUrl}" class="btn btn-icon btn-light-primary btn-active-primary btn-sm me-1 shadow-sm">
                                        <i class="ki-duotone ki-pencil fs-3"></i>
                                    </a>
                                    <button type="button" class="btn btn-icon btn-light-danger btn-active-danger btn-sm shadow-sm js-delete-item-btn" 
                                            data-id="${escapeHtml(it.id)}" data-name="${escapeHtml(it.name)}">
                                        <i class="ki-duotone ki-trash fs-3"></i>
                                    </button>
                                </td>
                            </tr>
                        `;
                    }).join('');

                    wireDeleteHandlers();
                } catch (e) {
                    setErrorRow(`Hata: ${escapeHtml(e.message)}`);
                }
            });

            resetCreateButton();
        })();
    </script>
}