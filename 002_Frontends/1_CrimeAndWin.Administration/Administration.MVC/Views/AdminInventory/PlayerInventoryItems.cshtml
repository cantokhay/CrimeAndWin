@model Administration.MVC.ViewModels.InventoryVMs.PlayerInventoryItemsVMs.PlayerInventoryItemsVM

@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@Html.AntiForgeryToken()

<div class="card mb-5">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Inventory Browser</span>
            <span class="text-muted mt-1 fw-bold fs-7">Player → Inventory → Items</span>
        </h3>
    </div>

    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Player</label>
                <select id="playerSelect" class="form-select">
                    <option value="">-- Player seç --</option>
                    @foreach (var p in Model.PlayerOptions)
                    {
                        <option value="@p.Value">@p.Text</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Inventory</label>
                <select id="inventorySelect" class="form-select" disabled>
                    <option value="">-- Önce player seç --</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!--begin::Tables Widget 13-->
<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Items</span>
            <span id="itemsCountText" class="text-muted mt-1 fw-bold fs-7">0 kayıt</span>
        </h3>

        <div class="card-toolbar">
            <a id="btnCreateItem"
               class="btn btn-sm btn-primary disabled"
               href="javascript:void(0)"
               title="Önce Inventory seçmelisin">
                Yeni Item
            </a>
        </div>
    </div>

    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                <thead>
                    <tr class="fw-bolder text-muted">
                        <th>Id</th>
                        <th>Name</th>
                        <th>Qty</th>
                        <th>Stats</th>
                        <th>Value</th>
                        <th>Created</th>
                        <th class="min-w-100px text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="itemsTbody">
                    <tr>
                        <td colspan="7" class="text-center text-muted py-6">
                            Player ve Inventory seçince itemlar burada görünecek.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
<!--end::Tables Widget 13-->
@section Scripts {
    <script>
        (function () {
            const playerSelect = document.getElementById('playerSelect');
            const inventorySelect = document.getElementById('inventorySelect');
            const itemsTbody = document.getElementById('itemsTbody');
            const itemsCountText = document.getElementById('itemsCountText');
            const btnCreateItem = document.getElementById('btnCreateItem');

            function setInfoRow(message) {
                itemsTbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="text-center text-muted py-6">${message}</td>
                    </tr>`;
                itemsCountText.textContent = `0 kayıt`;
            }

            function setErrorRow(message) {
                itemsTbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="text-center text-danger py-6">${message}</td>
                    </tr>`;
                itemsCountText.textContent = `0 kayıt`;
            }

            function escapeHtml(str) {
                if (str === null || str === undefined) return '';
                return String(str)
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#039;');
            }

            // API currency number ya da string dönebilir.
            // number: 1/2/3  => Gold/Gem/Credit
            // string: "Gold" => Gold
            function currencyToText(currency) {
                if (currency === null || currency === undefined) return '';
                if (typeof currency === 'number') {
                    switch (currency) {
                        case 1: return 'Gold';
                        case 2: return 'Gem';
                        case 3: return 'Credit';
                        default: return String(currency);
                    }
                }
                return String(currency);
            }

            function formatDate(dateValue) {
                if (!dateValue) return '';
                const d = new Date(dateValue);
                if (isNaN(d.getTime())) return '';
                return d.toLocaleString();
            }

            async function safeFetchJson(url) {
                const res = await fetch(url);

                if (!res.ok) {
                    let errText = '';
                    try {
                        const maybeJson = await res.json();
                        errText = JSON.stringify(maybeJson);
                    } catch {
                        try {
                            errText = await res.text();
                        } catch {
                            errText = `HTTP ${res.status}`;
                        }
                    }
                    throw new Error(`HTTP ${res.status} - ${errText}`);
                }

                return await res.json();
            }

            function resetCreateButton() {
                btnCreateItem.classList.add('disabled');
                btnCreateItem.href = 'javascript:void(0)';
                btnCreateItem.setAttribute('title', 'Önce Inventory seçmelisin');
            }

            function enableCreateButton(inventoryId) {
                btnCreateItem.classList.remove('disabled');
                btnCreateItem.removeAttribute('title');
                btnCreateItem.href = `@Url.Action("CreateItem", "AdminInventory")?inventoryId=${encodeURIComponent(inventoryId)}`;
            }

            function wireDeleteHandlers() {
                document.querySelectorAll('.js-delete-item-form').forEach(form => {
                    form.addEventListener('submit', async function (e) {
                        e.preventDefault();

                        if (!confirm('Bu item kaydını silmek istediğinize emin misiniz?')) return;

                        try {
                            const formData = new FormData(this);

                            const res = await fetch(`@Url.Action("DeleteItem", "AdminInventory")`, {
                                method: 'POST',
                                body: formData
                            });

                            const json = await res.json();

                            if (!json.success) {
                                alert('Silme sırasında hata oluştu.');
                                return;
                            }

                            // aynı inventory seçiliyken tekrar yükle
                            inventorySelect.dispatchEvent(new Event('change'));
                        } catch (err) {
                            alert('Silme sırasında hata oluştu.');
                        }
                    });
                });
            }

            // =========================
            // Player değişince inventory doldur
            // =========================
            playerSelect.addEventListener('change', async function () {
                const playerId = this.value;

                resetCreateButton();

                inventorySelect.disabled = true;
                inventorySelect.innerHTML = `<option value="">-- Inventory yükleniyor... --</option>`;
                setInfoRow('Inventory seçimi bekleniyor...');

                if (!playerId) {
                    inventorySelect.innerHTML = `<option value="">-- Önce player seç --</option>`;
                    return;
                }

                try {
                    const url = `@Url.Action("GetInventoriesByPlayer", "AdminInventory")?playerId=${encodeURIComponent(playerId)}`;
                    const list = await safeFetchJson(url);

                    if (!Array.isArray(list) || list.length === 0) {
                        inventorySelect.innerHTML = `<option value="">-- Bu player için inventory yok --</option>`;
                        inventorySelect.disabled = true;
                        setInfoRow('Bu player için inventory bulunamadı.');
                        return;
                    }

                    inventorySelect.innerHTML =
                        `<option value="">-- Inventory seç --</option>` +
                        list.map(x => `<option value="${escapeHtml(x.id)}">${escapeHtml(x.text)}</option>`).join('');

                    inventorySelect.disabled = false;
                    setInfoRow('Inventory seçince itemlar yüklenecek...');
                } catch (e) {
                    inventorySelect.innerHTML = `<option value="">-- Hata oluştu --</option>`;
                    inventorySelect.disabled = true;
                    setErrorRow(`Inventories yüklenirken hata oluştu: ${escapeHtml(e.message)}`);
                }
            });

            // =========================
            // Inventory değişince itemları getir
            // =========================
            inventorySelect.addEventListener('change', async function () {
                const inventoryId = this.value;

                resetCreateButton();

                if (!inventoryId) {
                    setInfoRow('Inventory seçimi bekleniyor...');
                    return;
                }

                enableCreateButton(inventoryId);
                setInfoRow('Itemlar yükleniyor...');

                try {
                    const url = `@Url.Action("GetItemsByInventory", "AdminInventory")?inventoryId=${encodeURIComponent(inventoryId)}`;
                    const items = await safeFetchJson(url);

                    if (!Array.isArray(items) || items.length === 0) {
                        itemsTbody.innerHTML = `
                            <tr>
                                <td colspan="7" class="text-center text-muted py-6">
                                    Bu inventory içinde item yok.
                                </td>
                            </tr>`;
                        itemsCountText.textContent = `0 kayıt`;
                        return;
                    }

                    itemsCountText.textContent = `${items.length} kayıt`;

                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

                    itemsTbody.innerHTML = items.map(it => {
                        const stats = `Dmg: ${escapeHtml(it.damage)} / Def: ${escapeHtml(it.defense)} / Pow: ${escapeHtml(it.power)}`;
                        const value = `${escapeHtml(it.amount)} (${escapeHtml(currencyToText(it.currencyText ?? it.currency))})`;

                        const editUrl = `@Url.Action("EditItem", "AdminInventory")/${encodeURIComponent(it.id)}`;

                        return `
                            <tr>
                                <td>${escapeHtml(it.id)}</td>
                                <td>${escapeHtml(it.name)}</td>
                                <td><span class="badge bg-info">${escapeHtml(it.quantity)}</span></td>
                                <td>${stats}</td>
                                <td>${value}</td>
                                <td>${escapeHtml(formatDate(it.createdAtUtc))}</td>
                                <td class="text-end">
                                    <a href="${editUrl}" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1" title="Düzenle">
                                        <span class="svg-icon svg-icon-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                                <path opacity="0.3" d="M21.4 8.35303L19.241 10.511L13.485 4.755L15.643 2.59595C16.0248 2.21423 16.5426 1.99988 17.0825 1.99988C17.6224 1.99988 18.1402 2.21423 18.522 2.59595L21.4 5.474C21.7817 5.85581 21.9962 6.37355 21.9962 6.91345C21.9962 7.45335 21.7817 7.97122 21.4 8.35303ZM3.68699 21.932L9.88699 19.865L4.13099 14.109L2.06399 20.309C1.98815 20.5354 1.97703 20.7787 2.03189 21.0111C2.08674 21.2436 2.2054 21.4561 2.37449 21.6248C2.54359 21.7934 2.75641 21.9115 2.989 21.9658C3.22158 22.0201 3.4647 22.0084 3.69099 21.932H3.68699Z" fill="currentColor" />
                                                <path d="M5.574 21.3L3.692 21.928C3.46591 22.0032 3.22334 22.0141 2.99144 21.9594C2.75954 21.9046 2.54744 21.7864 2.3789 21.6179C2.21036 21.4495 2.09202 21.2375 2.03711 21.0056C1.9822 20.7737 1.99289 20.5312 2.06799 20.3051L2.696 18.422L5.574 21.3ZM4.13499 14.105L9.891 19.861L19.245 10.507L13.489 4.75098L4.13499 14.105Z" fill="currentColor" />
                                            </svg>
                                        </span>
                                    </a>

                                    <form class="d-inline js-delete-item-form" method="post">
                                        <input type="hidden" name="id" value="${escapeHtml(it.id)}" />
                                        <input type="hidden" name="__RequestVerificationToken" value="${escapeHtml(token)}" />
                                        <button type="submit" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm" title="Sil">
                                            <span class="svg-icon svg-icon-3">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                                    <path d="M5 9C5 8.44772 5.44772 8 6 8H18C18.5523 8 19 8.44772 19 9V18C19 19.6569 17.6569 21 16 21H8C6.34315 21 5 19.6569 5 18V9Z" fill="currentColor" />
                                                    <path opacity="0.5" d="M5 5C5 4.44772 5.44772 4 6 4H18C18.5523 4 19 4.44772 19 5V5C19 5.55228 18.5523 6 18 6H6C5.44772 6 5 5.55228 5 5V5Z" fill="currentColor" />
                                                    <path opacity="0.5" d="M9 4C9 3.44772 9.44772 3 10 3H14C14.5523 3 15 3.44772 15 4V4H9V4Z" fill="currentColor" />
                                                </svg>
                                            </span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        `;
                    }).join('');

                    wireDeleteHandlers();
                } catch (e) {
                    setErrorRow(`Itemlar yüklenirken hata oluştu: ${escapeHtml(e.message)}`);
                }
            });

            // initial
            resetCreateButton();
        })();
    </script>
}