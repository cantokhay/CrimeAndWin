@model List<ResultPlayerVM>
@{
    ViewData["Title"] = "Oyuncu Envanter Takibi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!--begin::Toolbar-->
<div class="toolbar py-5 py-lg-15" id="kt_toolbar">
    <div id="kt_toolbar_container" class="container-xxl d-flex flex-stack flex-wrap">
        <div class="page-title d-flex flex-column me-3">
            <h1 class="d-flex text-white fw-bold my-1 fs-3">Kisisel Envanter Yonetimi</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                <li class="breadcrumb-item text-white opacity-75">Oyun Yonetimi</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75 text-hover-primary">Inventory</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75">Oyuncu Detay</li>
            </ul>
        </div>
    </div>
</div>
<!--end::Toolbar-->

<div class="card card-flush shadow-sm border-0 mb-5 mb-xl-8">
    <div class="card-header pt-7">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark fs-3">Envanter Sorgulama</span>
            <span class="text-gray-400 mt-1 fw-semibold fs-7">Oyuncu secerek envanter icerigini anlik goruntuleyin</span>
        </h3>
    </div>
    <div class="card-body pt-5">
        <div class="row g-9 mb-8">
            <div class="col-md-6 fv-row">
                <label class="required fs-6 fw-bold mb-2 text-primary">Oyuncu Secimi</label>
                <select id="player_select" class="form-select form-select-solid fw-bold" data-control="select2" data-placeholder="Bir oyuncu arayın...">
                    <option></option>
                    @foreach (var player in Model)
                    {
                        <option value="@player.Id">@(player.DisplayName ?? player.AppUserName ?? "Gizli") (@player.Id.ToString().Substring(0,8)...)</option>
                    }
                </select>
            </div>
            <div class="col-md-6 fv-row">
                <label class="fs-6 fw-bold mb-2 text-warning">Baglı Envanterler</label>
                <select id="inventory_select" class="form-select form-select-solid fw-bold" disabled>
                    <option value="">-- Once oyuncu secin --</option>
                </select>
            </div>
        </div>
        
        <div class="text-end" id="create_btn_container">
            <!-- Dinamik buton -->
        </div>
    </div>
</div>

<div class="card card-flush shadow-sm border-0">
    <div class="card-header py-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark fs-4">Envanter Icerigi</span>
            <span class="text-muted mt-1 fw-semibold fs-7" id="items_count_text">0 kayit listelendi</span>
        </h3>
    </div>
    <div class="card-body pt-0">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5">
                <thead>
                    <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-200px">Esya Bilgisi</th>
                        <th class="min-w-80px">Adet</th>
                        <th class="min-w-150px text-center">Teknik Veriler</th>
                        <th class="min-w-120px text-end">Ekonomik Deger</th>
                        <th class="min-w-150px text-end">Eklenme Tarihi</th>
                        <th class="text-end min-w-100px">Islemler</th>
                    </tr>
                </thead>
                <tbody class="fw-semibold text-gray-600" id="items_tbody">
                    <tr>
                        <td colspan="6" class="text-center text-muted py-10">
                            Lutfen sorgulama yapmak icin yukarıdan secim yapın.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const playerSelect = document.getElementById('player_select');
            const inventorySelect = document.getElementById('inventory_select');
            const itemsTbody = document.getElementById('items_tbody');
            const itemsCountText = document.getElementById('items_count_text');
            const createBtnContainer = document.getElementById('create_btn_container');

            function formatDate(str) {
                if(!str) return "-";
                const d = new Date(str);
                return d.toLocaleDateString() + " " + d.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            }

            function setInfoRow(msg) {
                itemsTbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-10"><span class="spinner-border spinner-border-sm me-2"></span>${msg}</td></tr>`;
            }

            playerSelect.addEventListener('change', async function () {
                const playerId = this.value;
                inventorySelect.disabled = true;
                inventorySelect.innerHTML = `<option value="">-- Yukleniyor... --</option>`;
                setInfoRow('Envanterler getiriliyor...');

                if (!playerId) {
                    inventorySelect.innerHTML = `<option value="">-- Once oyuncu secin --</option>`;
                    return;
                }

                try {
                    const res = await fetch(`@Url.Action("GetInventoriesByPlayer", "AdminInventory")?playerId=${playerId}`);
                    const list = await res.json();

                    if (!list || list.length === 0) {
                        inventorySelect.innerHTML = `<option value="">-- Kayit bulunamadı --</option>`;
                        return;
                    }

                    inventorySelect.innerHTML = `<option value="">-- Envanter secin --</option>` + 
                        list.map(x => `<option value="${x.id}">${x.text}</option>`).join('');
                    inventorySelect.disabled = false;
                    setInfoRow('Envanter secince esyalar listelenecek.');
                } catch (e) {
                    console.error(e);
                }
            });

            inventorySelect.addEventListener('change', async function () {
                const invId = this.value;
                if (!invId) return;

                setInfoRow('Esyalar yukleniyor...');

                try {
                    const res = await fetch(`@Url.Action("GetItemsByInventory", "AdminInventory")?inventoryId=${invId}`);
                    const items = await res.json();

                    itemsCountText.textContent = `${items.length} kayit bulundu`;

                    if (items.length === 0) {
                        itemsTbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-10">Envanter bos.</td></tr>`;
                        return;
                    }

                    itemsTbody.innerHTML = items.map(it => `
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-35px me-3">
                                        <div class="symbol-label bg-light-warning text-warning fw-bold fs-7">${it.name[0]}</div>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bold mb-1 fs-6">${it.name}</span>
                                        <span class="text-muted fs-9">#${it.id.substring(0,8)}</span>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge badge-light-primary fw-bold">${it.quantity} ADET</span></td>
                            <td class="text-center text-muted fs-8">
                                <span class="badge badge-outline badge-danger fs-9">DMG: ${it.damage}</span>
                                <span class="badge badge-outline badge-success fs-9">DEF: ${it.defense}</span>
                            </td>
                            <td class="text-end">
                                <span class="text-dark fw-bold">${it.amount}</span>
                                <span class="text-muted fs-9 d-block">${it.currencyText || "USD"}</span>
                            </td>
                            <td class="text-end text-muted fs-8">${formatDate(it.createdAtUtc)}</td>
                            <td class="text-end">
                                <a href="@Url.Action("EditItem", "AdminInventory")/${it.id}" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                    <i class="ki-duotone ki-pencil fs-2"></i>
                                </a>
                            </td>
                        </tr>
                    `).join('');
                } catch (e) {
                    console.error(e);
                }
            });
        })();
    </script>
}
