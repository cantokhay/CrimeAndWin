@model UpdateInventoryVM

@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Inventory Düzenle</h3>
        <a asp-action="Inventories" asp-controller="AdminInventory" class="btn btn-sm btn-light">Listeye Dön</a>
    </div>

    <div class="card-body">
        <form asp-action="EditInventory" asp-controller="AdminInventory" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-3">
                <div class="col-md-12">
                    <label class="form-label">Player</label>
                    <select asp-for="PlayerId" asp-items="Model.PlayerOptions" class="form-select"></select>
                    <span asp-validation-for="PlayerId" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Güncelle</button>
                <a asp-action="Inventories" asp-controller="AdminInventory" class="btn btn-light ms-2">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}