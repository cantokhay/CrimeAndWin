@model List<ActionLogDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Aksiyon Günlükleri (Action Logs)";
    int currentPage = ViewBag.CurrentPage ?? 1;
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-warning">
                            <i class="ki-duotone ki-scroll fs-2x text-warning"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Toplam Log</span>
                        <span class="fs-2 fw-bold mb-0">@Model.Count</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-success">
                            <i class="ki-duotone ki-chart-line-star fs-2x text-success"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Genel Başarı</span>
                        <span class="fs-2 fw-bold mb-0 text-success">
                            @(Model.Any() ? (Model.Count(x => x.IsSuccess) * 100 / Model.Count) : 0)%
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-danger border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-danger">
                            <i class="ki-duotone ki-electricity fs-2x text-danger"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Harcanan Enerji</span>
                        <span class="fs-2 fw-bold mb-0 text-danger">
                            @(Model.Any() ? Model.Sum(x => x.EnergyCost) : 0)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Aksiyon Günlükleri</span>
            <span class="text-muted mt-1 fw-bold fs-7">Sistemdeki tüm oyuncu hareketlerinin detaylı kaydı</span>
        </h3>
    </div>
    <div class="card-body py-3">
        @if (Model == null || !Model.Any())
        {
            <div class="notice d-flex bg-light-info rounded border-info border border-dashed p-6">
                <i class="ki-duotone ki-information-5 fs-2tx text-info me-4"></i>
                <div class="d-flex flex-stack flex-grow-1">
                    <div class="fw-bold">
                        <h4 class="text-gray-900 fw-bolder">Kayıt Bulunamadı</h4>
                        <div class="fs-6 text-gray-700">Şu an gösterilecek aksiyon kaydı bulunmamaktadır.</div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                    <thead>
                        <tr class="fw-bolder text-muted">
                            <th class="min-w-150px">Zaman / Oyuncu</th>
                            <th>Aksiyon Tipi</th>
                            <th>Sonuç / Oran</th>
                            <th>Enerji</th>
                            <th class="min-w-100px text-end">Detaylar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bolder fs-6">@item.PlayerName</span>
                                        <span class="text-muted fw-bold fs-7">@item.ActionAt.ToLocalTime().ToString("g")</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-light-warning fw-bold">@item.ActionType</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center mb-1">
                                        @if (item.IsSuccess)
                                        {
                                            <span class="badge badge-light-success py-1 px-3 shadow-sm me-2">Başarılı</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-light-danger py-1 px-3 shadow-sm me-2">Başarısız</span>
                                        }
                                        <span class="text-muted fw-bold fs-8">%@((item.SuccessRate * 100).ToString("F1"))</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-danger fw-bolder fs-6">-@item.EnergyCost Enerji</span>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-icon btn-bg-light btn-active-color-warning btn-sm" 
                                            data-bs-toggle="tooltip" data-bs-html="true" 
                                            title="Lvl Bonus: @item.LevelBonus<br/>Equip Bonus: @item.EquipBonus<br/>Varyasyon: @item.RandomVariation">
                                        <i class="ki-duotone ki-information-5 fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="d-flex flex-stack flex-wrap pt-10">
                <div class="fs-6 fw-bold text-gray-700">Sayfa @currentPage</div>
                <ul class="pagination">
                    @if (currentPage > 1)
                    {
                        <li class="page-item previous">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)">
                                <i class="ki-duotone ki-left fs-2"></i>
                            </a>
                        </li>
                    }
                    <li class="page-item active"><a class="page-link">@currentPage</a></li>
                    <li class="page-item next">
                        <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)">
                            <i class="ki-duotone ki-right fs-2"></i>
                        </a>
                    </li>
                </ul>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        });
    </script>
}
