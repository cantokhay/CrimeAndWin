@model Administration.MVC.ViewModels.SettingsVMs.GlobalSettingsVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sistem Yapılandırması";
}

<div class="card mb-5 mb-xl-10 shadow-sm">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Global Oyun Parametreleri</span>
            <span class="text-muted mt-1 fw-bold fs-7">Tüm mikroservislerin ortak kullandığı dinamik yapılandırma ayarları</span>
        </h3>
    </div>
    <div class="card-body p-9">
        <form asp-action="UpdateSettings" asp-controller="AdminSettings" method="post" id="kt_settings_form">
            @Html.AntiForgeryToken()

            <!-- Maintenance Mode -->
            <div class="row mb-10">
                <label class="col-lg-4 col-form-label fw-bold fs-6">Sistem Bakım Modu</label>
                <div class="col-lg-8 d-flex align-items-center">
                    <div class="form-check form-switch form-check-custom form-check-solid">
                        <input class="form-check-input h-30px w-50px" type="checkbox" asp-for="IsMaintenanceMode" id="maintenanceSwitch" />
                        <label class="form-check-label fw-bold text-gray-600 ms-3" for="maintenanceSwitch"> 
                            Bakım Modu Aktif (Oyuncular giriş yapamaz)
                        </label>
                    </div>
                </div>
            </div>

            <div class="separator separator-dashed my-6"></div>

            <!-- Multipliers -->
            <div class="row mb-6">
                <label class="col-lg-4 col-form-label fw-bold fs-6 mt-2">Oyun Mekaniği Çarpanları</label>
                <div class="col-lg-8">
                    <div class="row g-9">
                        <div class="col-md-6">
                            <label asp-for="SuccessRateMultiplier" class="form-label text-gray-600 fs-7 fw-bold mb-2">Başarı Oranı Çarpanı</label>
                            <div class="input-group input-group-solid shadow-none">
                                <span class="input-group-text bg-light-primary border-0">
                                    <i class="ki-duotone ki-chart-line-star fs-2 text-primary"></i>
                                </span>
                                <input type="number" asp-for="SuccessRateMultiplier" class="form-control" step="0.1" />
                            </div>
                            <div class="form-text fs-8 text-muted mt-2">Varsayılan: 1.0 (Normal zorluk)</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CooldownMultiplier" class="form-label text-gray-600 fs-7 fw-bold mb-2">Bekleme Süresi Çarpanı</label>
                            <div class="input-group input-group-solid shadow-none">
                                <span class="input-group-text bg-light-info border-0">
                                    <i class="ki-duotone ki-timer fs-2 text-info"></i>
                                </span>
                                <input type="number" asp-for="CooldownMultiplier" class="form-control" step="0.1" />
                            </div>
                            <div class="form-text fs-8 text-muted mt-2">Düşük değerler daha hızlı oyun deneyimi sağlar.</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Energy -->
            <div class="row mb-6">
                <label class="col-lg-4 col-form-label fw-bold fs-6 mt-2">Enerji Gereksinimi</label>
                <div class="col-lg-8">
                    <div class="input-group input-group-solid shadow-none">
                        <span class="input-group-text bg-light-warning border-0">
                            <i class="ki-duotone ki-flash-circle fs-2 text-warning"></i>
                        </span>
                        <input type="number" asp-for="MinEnergyRequired" class="form-control" />
                    </div>
                    <div class="form-text fs-8 text-muted mt-2">Herhangi bir aksiyon almak için gerekli minimum enerji miktarı.</div>
                </div>
            </div>

            <!-- Announcement -->
            <div class="row mb-10">
                <label class="col-lg-4 col-form-label fw-bold fs-6">Global Duyuru Mesajı</label>
                <div class="col-lg-8">
                    <textarea asp-for="GlobalAnnouncement" class="form-control form-control-solid border-0 fs-6" rows="4" placeholder="Tüm oyunculara anlık olarak iletilecek mesaj metni..."></textarea>
                    <div class="form-text fs-8 text-muted mt-2">HTML formatı desteklenmez, sadece düz metin giriniz.</div>
                </div>
            </div>

            <div class="d-flex justify-content-end border-top pt-8">
                <button type="submit" class="btn btn-primary" id="kt_settings_submit">
                    <span class="indicator-label">
                        <i class="ki-duotone ki-check fs-2 me-2"></i> Ayarları Değişikliklerini Kaydet
                    </span>
                    <span class="indicator-progress">
                        Lütfen bekleyin... <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                    </span>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-dismissible bg-light-info d-flex flex-column flex-sm-row p-7 mb-10 border border-info border-dashed">
    <i class="ki-duotone ki-information-5 fs-2hx text-info me-4 mb-5 mb-sm-0"></i>
    <div class="d-flex flex-column pe-0 pe-sm-10">
        <h4 class="fw-bold text-info">Sistem Hatırlatması</h4>
        <span class="fs-6 fs-semi-bold">Ayarlar kaydedildiği anda <strong>Message Bus</strong> üzerinden tüm bağlı mikroservislere (Action, Economy, Player vs.) anlık sinyal gönderilir. Değişiklikler genellikle 2-5 saniye içerisinde tüm sistemde aktif olur.</span>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#kt_settings_form').on('submit', function() {
                const $btn = $('#kt_settings_submit');
                $btn.find('.indicator-label').addClass('d-none');
                $btn.find('.indicator-progress').css('display', 'inline-block');
                $btn.prop('disabled', true);
            });
        });
    </script>
    <style>
        .indicator-progress { display: none; }
    </style>
}
