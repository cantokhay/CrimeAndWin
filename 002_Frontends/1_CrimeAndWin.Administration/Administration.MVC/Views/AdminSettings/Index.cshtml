@model Administration.MVC.ViewModels.SettingsVMs.GlobalSettingsVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sistem Çevre Ayarları";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Global Sistem Yapılandırması</span>
            <span class="text-muted mt-1 fw-bold fs-7">Tüm mikroservislerin davranışını etkileyen global parametreler</span>
        </h3>
    </div>
    <div class="card-body">
        <form asp-action="UpdateSettings" method="post" id="kt_settings_form">
            @Html.AntiForgeryToken()

            <!-- Maintenance Mode -->
            <div class="row mb-8">
                <label class="col-lg-3 col-form-label fw-bold fs-6">Sistem Durumu</label>
                <div class="col-lg-9 d-flex align-items-center">
                    <div class="form-check form-switch form-check-custom form-check-solid">
                        <input class="form-check-input" type="checkbox" asp-for="IsMaintenanceMode" id="maintenanceSwitch" />
                        <label class="form-check-label fw-bold text-gray-400 ms-3" for="maintenanceSwitch"> Bakım Modu (Aktif/Pasif) </label>
                    </div>
                </div>
            </div>

            <div class="separator separator-dashed my-6"></div>

            <!-- Multipliers -->
            <div class="row mb-8">
                <label class="col-lg-3 col-form-label fw-bold fs-6">Global Çarpanlar</label>
                <div class="col-lg-9">
                    <div class="row g-5">
                        <div class="col-md-6">
                            <label asp-for="SuccessRateMultiplier" class="form-label text-muted fs-7">Başarı Oranı Çarpanı (1.0 = Normal)</label>
                            <div class="input-group input-group-solid">
                                <span class="input-group-text"><i class="ki-duotone ki-graph-up fs-2"></i></span>
                                <input type="number" asp-for="SuccessRateMultiplier" class="form-control" step="0.1" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CooldownMultiplier" class="form-label text-muted fs-7">Bekleme Süresi Çarpanı (0.5 = Yarı Süre)</label>
                            <div class="input-group input-group-solid">
                                <span class="input-group-text"><i class="ki-duotone ki-time fs-2"></i></span>
                                <input type="number" asp-for="CooldownMultiplier" class="form-control" step="0.1" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Energy & Announcement -->
            <div class="row mb-8">
                <label class="col-lg-3 col-form-label fw-bold fs-6">Sistem Dinamikleri</label>
                <div class="col-lg-9">
                    <div class="mb-5">
                        <label asp-for="MinEnergyRequired" class="form-label text-muted fs-7">Min. Aksiyon Enerjisi</label>
                        <input type="number" asp-for="MinEnergyRequired" class="form-control form-control-solid" />
                    </div>
                    <div>
                        <label asp-for="GlobalAnnouncement" class="form-label text-muted fs-7">Global Duyuru Metni</label>
                        <textarea asp-for="GlobalAnnouncement" class="form-control form-control-solid" rows="3" placeholder="Tüm kullanıcılara gösterilecek mesaj..."></textarea>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end pt-5">
                <button type="submit" class="btn btn-primary" id="kt_settings_submit">
                    <span class="indicator-label"><i class="ki-duotone ki-save-2 fs-2 me-2"></i> Ayarları Güncelle</span>
                    <span class="indicator-progress">Lütfen bekleyin... 
                    <span class="spinner-border spinner-border-sm align-middle ms-2"></span></span>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-dismissible bg-light-warning d-flex flex-column flex-sm-row p-5 mb-10 border border-warning border-dashed">
    <i class="ki-duotone ki-notification-on fs-2hx text-warning me-4 mb-5 mb-sm-0"></i>
    <div class="d-flex flex-column pe-0 pe-sm-10">
        <h4 class="fw-bold text-warning">Önemli Hatırlatma</h4>
        <span>Burada yapılan değişiklikler <strong>Event Bus</strong> üzerinden tüm mikroservislere anlık olarak iletilir. Bazı servislerin önbellek temizlemesi için 1-2 dakika gerekebilir.</span>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#kt_settings_form').on('submit', function() {
                $('#kt_settings_submit .indicator-label').addClass('d-none');
                $('#kt_settings_submit .indicator-progress').removeClass('d-none');
                $('#kt_settings_submit').prop('disabled', true);
            });
        });
    </script>
}
