@model List<CooldownDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Aktif Bekleme Süreleri (Cooldowns)";
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-primary">
                            <i class="ki-duotone ki-timer fs-2x text-primary"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Aktif Cooldown</span>
                        <span class="fs-2 fw-bold mb-0">@(Model?.Count ?? 0)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-warning">
                            <i class="ki-duotone ki-time fs-2x text-warning"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Kritik ( < 1 Dakika )</span>
                        <span class="fs-2 fw-bold mb-0 text-warning">
                            @(Model?.Count(x => (x.CooldownEndsAt - DateTime.UtcNow).TotalSeconds < 60) ?? 0)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Aktif Bekleme Süreleri</span>
            <span class="text-muted mt-1 fw-bold fs-7">Oyuncuların aksiyon yapmasını engelleyen aktif süreler</span>
        </h3>
    </div>
    <div class="card-body py-3">
        @if (Model == null || !Model.Any())
        {
            <div class="notice d-flex bg-light-info rounded border-info border border-dashed p-6">
                <i class="ki-duotone ki-information-5 fs-2tx text-info me-4"></i>
                <div class="d-flex flex-stack flex-grow-1">
                    <div class="fw-bold">
                        <h4 class="text-gray-900 fw-bolder">Kayıt Bulunamadı</h4>
                        <div class="fs-6 text-gray-700">Şu an sistemde bekleyen (cooldown) oyuncu bulunmamaktadır.</div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                    <thead>
                        <tr class="fw-bolder text-muted">
                            <th class="min-w-150px">Oyuncu Bilgisi</th>
                            <th>Aksiyon Tipi</th>
                            <th>Bitiş Zamanı (Yerel)</th>
                            <th class="min-w-100px text-end">Kalan Süre</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var remainingSeconds = (item.CooldownEndsAt - DateTime.UtcNow).TotalSeconds;
                            if (remainingSeconds < 0) remainingSeconds = 0;
                            
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bolder text-hover-primary fs-6">@item.PlayerName</span>
                                        <span class="text-muted fw-bold fs-7">@item.PlayerId.ToString().Substring(0, 8)...</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-light-info fw-bold">@item.ActionType</span>
                                </td>
                                <td>
                                    <span class="text-muted fw-bold d-block fs-7">@item.CooldownEndsAt.ToLocalTime().ToString("g")</span>
                                </td>
                                <td class="text-end">
                                    @{
                                        var minutes = (int)remainingSeconds / 60;
                                        var seconds = (int)remainingSeconds % 60;
                                        var badgeColor = remainingSeconds < 60 ? "warning" : "primary";
                                    }
                                    <span class="badge badge-light-@badgeColor fs-7 fw-bolder">
                                        <i class="ki-duotone ki-watch fs-6 text-@badgeColor me-1"></i> @minutes.ToString("D2"):@seconds.ToString("D2")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
