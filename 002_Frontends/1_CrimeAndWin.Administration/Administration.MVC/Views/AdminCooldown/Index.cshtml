@model List<CooldownDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cooldown Takibi";
}

<div class="row g-5 g-xl-10 mb-8 mt-5 justify-content-center">
    <div class="col-md-3">
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-primary">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@(Model?.Count ?? 0)</span>
                        <span class="badge badge-light-primary border border-primary border-dashed fs-7 fw-bold px-3 py-1">Aktif</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Sistemdeki Aktif Cooldownlar</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5 text-primary">
                <i class="ki-duotone ki-timer fs-3x"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        @{
            var criticalCount = Model?.Count(x => (x.CooldownEndsAt - DateTime.UtcNow).TotalSeconds < 60) ?? 0;
        }
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-warning">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@criticalCount</span>
                        <span class="badge badge-light-warning border border-warning border-dashed fs-7 fw-bold px-3 py-1">Kritik</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Bitişe 1 Dakikadan Az Kalanlar</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5 text-warning">
                <i class="ki-duotone ki-time fs-3x"></i>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8 shadow-sm">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Aktif Bekleme Süreleri (Cooldowns)</span>
            <span class="text-muted mt-1 fw-bold fs-7">Oyuncuların aksiyon yapmasını engelleyen aktif süreler</span>
        </h3>
    </div>
    <div class="card-body py-3">
        @if (Model == null || !Model.Any())
        {
            <div class="notice d-flex bg-light-info rounded border-info border border-dashed p-6 my-10">
                <span class="svg-icon svg-icon-2tx svg-icon-info me-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <rect opacity="0.3" x="2" y="2" width="20" height="20" rx="10" fill="currentColor"></rect>
                        <rect x="11" y="14" width="7" height="2" rx="1" transform="rotate(-90 11 14)" fill="currentColor"></rect>
                        <rect x="11" y="17" width="2" height="2" rx="1" transform="rotate(-90 11 17)" fill="currentColor"></rect>
                    </svg>
                </span>
                <div class="d-flex flex-stack flex-grow-1">
                    <div class="fw-bold">
                        <h4 class="text-gray-900 fw-bold">Şu an aktif bekleme süresi yok</h4>
                        <div class="fs-6 text-gray-700">Tüm oyuncular serbest ve aksiyon almaya hazır durumda.</div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-4">
                    <thead>
                        <tr class="fw-bold text-muted bg-light">
                            <th class="ps-4 rounded-start min-w-150px">Oyuncu Bilgisi</th>
                            <th>Aksiyon Tipi / Kanalı</th>
                            <th class="text-center">Bitiş Zamanı</th>
                            <th class="min-w-100px text-end pe-4 rounded-end">Kalan Süre</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var remainingSeconds = (item.CooldownEndsAt - DateTime.UtcNow).TotalSeconds;
                            if (remainingSeconds < 0) remainingSeconds = 0;
                            
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="symbol symbol-35px me-3">
                                            <span class="symbol-label bg-light-primary text-primary fw-bold">@item.PlayerName[0]</span>
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="text-dark fw-bold text-hover-primary mb-1 fs-6">@item.PlayerName</span>
                                            <span class="text-muted fw-semi-bold fs-8">ID: @item.PlayerId.ToString().Substring(0, 8)</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bold fs-7 mb-1">@item.ActionType</span>
                                        <span class="badge badge-light-secondary fs-9 w-fit-content">Hizmet: Action.API</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="text-muted fw-bold d-block fs-8">@item.CooldownEndsAt.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <span class="text-muted fw-semi-bold fs-9">@item.CooldownEndsAt.ToLocalTime().ToString("dd MMM")</span>
                                </td>
                                <td class="text-end pe-4">
                                    @{
                                        var minutes = (int)remainingSeconds / 60;
                                        var seconds = (int)remainingSeconds % 60;
                                        var badgeColor = remainingSeconds < 60 ? "danger" : "primary";
                                    }
                                    <span class="badge badge-light-@badgeColor border border-@badgeColor border-dashed fs-7 fw-bold px-4 py-2">
                                        <i class="ki-duotone ki-watch fs-6 text-@badgeColor me-1"></i> @minutes.ToString("D2"):@seconds.ToString("D2")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
