@model Administration.MVC.ViewModels.DashboardVMs.AdminDashboardVM
@{
    ViewData["Title"] = "Genel Durum";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <!-- 1. Toplam Oyuncu -->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-primary text-primary">
                            <i class="ki-duotone ki-people fs-2x">
                                <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span>
                            </i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Aktif Oyuncu</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">@Model.TotalPlayerCount.ToString("N0")</span>
                    <span class="badge badge-light-primary fs-base">+@Model.NewPlayersToday BugǬn</span>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Ekonomi: Temiz & Kara Para -->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-success text-success">
                            <i class="ki-duotone ki-finance-2 fs-2x">
                                <span class="path1"></span><span class="path2"></span><span class="path3"></span>
                            </i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Ekonomi Hacmi</span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-2 fw-bold text-dark d-block">@Model.TotalCashInEconomy.ToString("C0")</span>
                        <span class="text-muted fs-8 fw-bold">CASH (TEMZ)</span>
                    </div>
                    <div class="text-end">
                        <span class="fs-2 fw-bold text-danger d-block">@Model.TotalBlackMoneyInEconomy.ToString("C0")</span>
                        <span class="text-muted fs-8 fw-bold">DIRTY (KARA)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Sistem Iss & Basknlar -->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-danger border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-danger text-danger">
                            <i class="ki-duotone ki-shield-search fs-2x">
                                <span class="path1"></span><span class="path2"></span><span class="path3"></span>
                            </i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Sistem Iss</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">%@Model.AveragePlayerHeat.ToString("N1")</span>
                    @if (Model.ActiveRaidsToday > 0) {
                        <span class="badge badge-danger blink fs-base">@Model.ActiveRaidsToday BASKIN</span>
                    } else {
                        <span class="badge badge-light-success fs-base">STABL</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 4. Aksiyon BaYar Oran -->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-info border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-info text-info">
                            <i class="ki-duotone ki-chart-line-4 fs-2x">
                                <span class="path1"></span><span class="path2"></span><span class="path3"></span>
                            </i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Su BaYars</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">%@Model.AverageActionSuccessRate.ToString("N1")</span>
                    <span class="text-muted fs-7">(@Model.TotalActionsToday Ylem)</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-5 g-xl-10">
    <div class="col-xl-8">
        <div class="card card-flush h-xl-100 shadow-sm border-0">
            <div class="card-header pt-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-dark fs-3">Su TrafiYi & BǬyǬme</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Global aksiyon hacim analizi</span>
                </h3>
            </div>
            <div class="card-body pt-0 px-0">
                <canvas id="kt_dashboard_chart" style="height: 350px"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card card-flush h-xl-100 shadow-sm border-0">
            <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-dark fs-3">Canl Aktivite AkYY</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Sertifikal su kayıtlar</span>
                </h3>
            </div>
            <div class="card-body pt-5">
                @foreach (var item in Model.RecentActions)
                {
                    <div class="d-flex align-items-center mb-6">
                        <div class="symbol symbol-35px me-4">
                            <span class="symbol-label bg-light-@(item.IsSuccess ? "success" : "danger")">
                                <i class="ki-duotone ki-@(item.IsSuccess ? "check-circle" : "cross-circle") fs-2 text-@(item.IsSuccess ? "success" : "danger")">
                                    <span class="path1"></span><span class="path2"></span>
                                </i>
                            </span>
                        </div>
                        <div class="flex-grow-1">
                            <span class="text-gray-800 text-hover-primary fw-bold fs-6">@item.ActionName</span>
                            <span class="text-muted d-block fw-bold fs-8">Oyuncu: @item.PlayerName</span>
                        </div>
                        <span class="badge badge-light-@(item.IsSuccess ? "success" : "danger") fw-bold fs-8">@item.Timestamp.ToString("HH:mm")</span>
                    </div>
                }

                @if (Model.RecentFailures.Any())
                {
                    <div class="separator separator-dashed my-4"></div>
                    <h4 class="fs-7 fw-bold text-danger mb-4">Kritik Hatalar (System)</h4>
                    @foreach (var fail in Model.RecentFailures)
                    {
                        <div class="d-flex align-items-center mb-4 bg-light-danger p-3 rounded border border-danger border-dotted">
                            <div class="flex-grow-1">
                                <span class="text-danger fw-bold fs-8">@fail.SagaType</span>
                                <span class="text-muted d-block fs-9 truncate-1">@fail.ErrorMessage</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            var ctx = document.getElementById('kt_dashboard_chart').getContext('2d');
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Pzt', 'Sal', 'ar', 'Per', 'Cum', 'Cmt', 'Paz'],
                    datasets: [{
                        label: 'Kara Para Hacmi',
                        data: @Html.Raw(Model.ActionVolumeChartData),
                        borderColor: '#F1416C',
                        backgroundColor: 'rgba(241, 65, 108, 0.1)',
                        fill: true,
                        tension: 0.4
                    }, {
                        label: 'Temiz Para Hacmi',
                        data: @Html.Raw(Model.SuccessRateChartData),
                        borderColor: '#50CD89',
                        backgroundColor: 'transparent',
                        borderDash: [5, 5],
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        });
    </script>
}

<style>
    .truncate-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .blink {
        animation: blink-animation 1s steps(5, start) infinite;
    }
    @@keyframes blink-animation {
        to { visibility: hidden; }
    }
</style>
