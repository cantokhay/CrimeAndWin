@model Administration.MVC.ViewModels.DashboardVMs.AdminDashboardVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yönetim Paneli Analiz";
}

<!--begin::Row-->
<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <!--begin::Col-->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4 h-100">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-success">
                            <i class="ki-duotone ki-check-circle fs-2 text-success"></i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Sistem Sağlığı</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">%@((Model.TotalServiceCount > 0) ? (Model.HealthyServiceCount * 100 / Model.TotalServiceCount) : 0)</span>
                    <span class="badge badge-light-success fs-base">@Model.HealthyServiceCount / @Model.TotalServiceCount</span>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->

    <!--begin::Col-->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4 h-100">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-primary">
                            <i class="ki-duotone ki-people fs-2 text-primary"></i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Toplam Oyuncu</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">@Model.TotalPlayerCount</span>
                    <span class="badge badge-light-primary fs-base">+@Model.NewPlayersToday Bugün</span>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->

    <!--begin::Col-->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4 h-100">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-warning">
                            <i class="ki-duotone ki-wallet fs-2 text-warning"></i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Ekonomi Likidite</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">@Model.TotalCashInEconomy.ToString("N0")</span>
                    <span class="text-muted fs-base fw-bold">CASH</span>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->

    <!--begin::Col-->
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-info border-4 h-100">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-info">
                            <i class="ki-duotone ki-graph-up fs-2 text-info"></i>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Aksiyon Başarısı</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">%@Model.AverageActionSuccessRate.ToString("N0")</span>
                    <span class="badge badge-light-info fs-base">@Model.TotalActionsToday İşlem</span>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->
</div>
<!--end::Row-->

<!--begin::Row-->
<div class="row g-5 g-xl-10">
    <!--begin::Col-->
    <div class="col-xl-8">
        <div class="card card-flush h-xl-100">
            <div class="card-header pt-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-dark">Aksiyon Hacmi & Başarı Oranı</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-6">Son 7 günlük aktivite analizi</span>
                </h3>
            </div>
            <div class="card-body pt-0 px-0">
                <canvas id="kt_dashboard_chart" style="height: 350px"></canvas>
            </div>
        </div>
    </div>
    <!--end::Col-->

    <!--begin::Col-->
    <div class="col-xl-4">
        <div class="card card-flush h-xl-100">
            <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-dark">Son Aktiviteler</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-6">Sistem üzerinden geçen son aksiyonlar</span>
                </h3>
            </div>
            <div class="card-body pt-5">
                @foreach (var item in Model.RecentActions)
                {
                    <div class="d-flex align-items-center mb-6">
                        <div class="symbol symbol-35px me-4">
                            <span class="symbol-label bg-light-@(item.IsSuccess ? "success" : "danger")">
                                <i class="ki-duotone ki-@(item.IsSuccess ? "check" : "cross") fs-4 text-@(item.IsSuccess ? "success" : "danger")"></i>
                            </span>
                        </div>
                        <div class="flex-grow-1">
                            <span class="text-gray-800 text-hover-primary fw-bold fs-6">@item.ActionName</span>
                            <span class="text-muted d-block fw-bold">Oyuncu: @item.PlayerName</span>
                        </div>
                        <span class="badge badge-light fw-bold fs-8">@item.Timestamp.ToString("HH:mm")</span>
                    </div>
                }

                @if (Model.RecentFailures.Any())
                {
                    <div class="separator separator-dashed my-4"></div>
                    <h4 class="fs-6 fw-bold text-danger mb-4">Kritik Hatalar (Saga)</h4>
                    @foreach (var fail in Model.RecentFailures)
                    {
                        <div class="d-flex align-items-center mb-4 bg-light-danger p-3 rounded">
                            <div class="flex-grow-1">
                                <span class="text-danger fw-bold fs-7">@fail.SagaType</span>
                                <span class="text-muted d-block fs-8 truncate-1">@fail.ErrorMessage</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <!--end::Col-->
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            var ctx = document.getElementById('kt_dashboard_chart').getContext('2d');
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt', 'Paz'],
                    datasets: [{
                        label: 'İşlem Hacmi',
                        data: @Html.Raw(Model.ActionVolumeChartData),
                        borderColor: '#009EF7',
                        backgroundColor: 'rgba(0, 158, 247, 0.1)',
                        fill: true,
                        tension: 0.4
                    }, {
                        label: 'Başarı Skoru',
                        data: @Html.Raw(Model.SuccessRateChartData),
                        borderColor: '#50CD89',
                        backgroundColor: 'transparent',
                        borderDash: [5, 5],
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        });
    </script>
}

<style>
    .truncate-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
