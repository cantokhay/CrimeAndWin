@model Administration.MVC.ViewModels.DashboardVMs.AdminDashboardVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yönetim Paneli Analiz";
}

<!--begin::Row-->
<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-success">
                            <span class="svg-icon svg-icon-2 svg-icon-success">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                    <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22ZM12 6V12L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Sistem Sağlığı</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">%@((Model.TotalServiceCount > 0) ? (Model.HealthyServiceCount * 100 / Model.TotalServiceCount) : 0)</span>
                    <span class="badge badge-light-success fs-base">@Model.HealthyServiceCount / @Model.TotalServiceCount</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-primary">
                            <span class="svg-icon svg-icon-2 svg-icon-primary">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                    <path d="M17 21V19C17 17.9391 16.5786 16.9217 15.8284 16.1716C15.0783 15.4214 14.0609 15 13 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M9 11C11.2091 11 13 9.20914 13 7C13 4.79086 11.2091 3 9 3C6.79086 3 5 4.79086 5 7C5 9.20914 6.79086 11 9 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M23 21V19C22.9993 18.1137 22.7044 17.2522 22.1614 16.5523C21.6184 15.8524 20.8581 15.3516 20 15.12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M16 3.13C16.8604 3.35031 17.623 3.85071 18.1676 4.55232C18.7122 5.25392 19.0078 6.11683 19.0078 7.005C19.0078 7.89318 18.7122 8.75608 18.1676 9.45768C17.623 10.1593 16.8604 10.6597 16 10.88" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Toplam Oyuncu</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">@Model.TotalPlayerCount</span>
                    <span class="badge badge-light-primary fs-base">+@Model.NewPlayersToday Bugün</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-warning">
                            <span class="svg-icon svg-icon-2 svg-icon-warning">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                    <path d="M20 12V8H6V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <rect x="2" y="6" width="20" height="12" rx="2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M12 12H12.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Ekonomi Likidite</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">@Model.TotalCashInEconomy.ToString("N0")</span>
                    <span class="text-muted fs-base fw-bold">CASH</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-info border-4 h-100 py-2">
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-2">
                    <div class="symbol symbol-40px me-3">
                        <span class="symbol-label bg-light-info">
                            <span class="svg-icon svg-icon-2 svg-icon-info">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                    <path d="M22 12H18L15 21L9 3L6 12H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                        </span>
                    </div>
                    <span class="text-gray-400 fw-bold fs-6">Aksiyon Başarısı</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-2hx fw-bold text-dark me-2">%@Model.AverageActionSuccessRate.ToString("N0")</span>
                    <span class="badge badge-light-info fs-base">@Model.TotalActionsToday İşlem</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-5 g-xl-10">
    <div class="col-xl-8">
        <div class="card card-flush h-xl-100">
            <div class="card-header pt-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-dark fs-3">Aksiyon Hacmi & Başarı Oranı</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Son 7 günlük aktivite analizi</span>
                </h3>
            </div>
            <div class="card-body pt-0 px-0">
                <canvas id="kt_dashboard_chart" style="height: 350px"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card card-flush h-xl-100">
            <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-dark fs-3">Son Aktiviteler</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Sistem üzerinden geçen son aksiyonlar</span>
                </h3>
            </div>
            <div class="card-body pt-5">
                @foreach (var item in Model.RecentActions)
                {
                    <div class="d-flex align-items-center mb-6">
                        <div class="symbol symbol-35px me-4">
                            <span class="symbol-label bg-light-@(item.IsSuccess ? "success" : "danger")">
                                <span class="svg-icon svg-icon-3 svg-icon-@(item.IsSuccess ? "success" : "danger")">
                                    @if(item.IsSuccess) {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    } else {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    }
                                </span>
                            </span>
                        </div>
                        <div class="flex-grow-1">
                            <span class="text-gray-800 text-hover-primary fw-bold fs-6">@item.ActionName</span>
                            <span class="text-muted d-block fw-bold fs-8">Oyuncu: @item.PlayerName</span>
                        </div>
                        <span class="badge badge-light fw-bold fs-8">@item.Timestamp.ToString("HH:mm")</span>
                    </div>
                }

                @if (Model.RecentFailures.Any())
                {
                    <div class="separator separator-dashed my-4"></div>
                    <h4 class="fs-7 fw-bold text-danger mb-4">Kritik Hatalar (Saga)</h4>
                    @foreach (var fail in Model.RecentFailures)
                    {
                        <div class="d-flex align-items-center mb-4 bg-light-danger p-3 rounded">
                            <div class="flex-grow-1">
                                <span class="text-danger fw-bold fs-8">@fail.SagaType</span>
                                <span class="text-muted d-block fs-9 truncate-1">@fail.ErrorMessage</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            var ctx = document.getElementById('kt_dashboard_chart').getContext('2d');
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt', 'Paz'],
                    datasets: [{
                        label: 'İşlem Hacmi',
                        data: @Html.Raw(Model.ActionVolumeChartData),
                        borderColor: '#009EF7',
                        backgroundColor: 'rgba(0, 158, 247, 0.1)',
                        fill: true,
                        tension: 0.4
                    }, {
                        label: 'Başarı Skoru',
                        data: @Html.Raw(Model.SuccessRateChartData),
                        borderColor: '#50CD89',
                        backgroundColor: 'transparent',
                        borderDash: [5, 5],
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        });
    </script>
}

<style>
    .truncate-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
