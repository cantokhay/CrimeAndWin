@model List<PlayerEnergyDto>
@{
    ViewData["Title"] = "Oyuncu Enerji Durumu";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Oyuncu Enerji Durumu</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-3">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="energyTable">
                    <thead>
                        <tr>
                            <th>Oyuncu Adı</th>
                            <th>Enerji (Mevcut/Max)</th>
                            <th>Dolum Oranı</th>
                            <th>Son Yenileme</th>
                            <th>Aktif Boost</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.PlayerName <br/><small class="text-muted">@item.PlayerId</small></td>
                                <td>@item.CurrentEnergy / @item.MaxEnergy</td>
                                <td style="width: 200px;">
                                    @{
                                        var current = item.CurrentEnergy;
                                        var max = item.MaxEnergy > 0 ? item.MaxEnergy : 100;
                                        var percent = (current * 100 / max);
                                        if (percent > 100) percent = 100;
                                        var color = percent < 20 ? "bg-danger" : (percent < 50 ? "bg-warning" : "bg-success");
                                    }
                                    <div class="progress">
                                        <div class="progress-bar @color" role="progressbar" style="width: @percent%" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100">@percent%</div>
                                    </div>
                                </td>
                                <td>@item.LastRefillAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ActiveBoostItem))
                                    {
                                        <span class="badge bg-success">
                                            @item.ActiveBoostItem 
                                            @if (item.BoostExpiresAt.HasValue) 
                                            {
                                                <br/>
                                                <small>Bitiş: @item.BoostExpiresAt.Value.ToLocalTime().ToString("g")</small>
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#refillModal" data-playerid="@item.PlayerId" data-playername="@(string.IsNullOrEmpty(item.PlayerName) ? item.PlayerId.ToString() : item.PlayerName)">
                                        Enerji Ekle
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Refill Modal -->
<div class="modal fade" id="refillModal" tabindex="-1" aria-labelledby="refillModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="ManualRefill" asp-controller="Energy" method="post">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="refillModalLabel">Manuel Enerji Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="playerId" id="modalPlayerId" />
                    <div class="mb-3">
                        <label class="form-label">Oyuncu:</label>
                        <input type="text" class="form-control" id="modalPlayerName" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Miktar:</label>
                        <input type="number" name="amount" class="form-control" min="1" max="100" value="10" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var refillModal = document.getElementById('refillModal')
        refillModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            var playerId = button.getAttribute('data-playerid')
            var playerName = button.getAttribute('data-playername')
            
            document.getElementById('modalPlayerId').value = playerId
            document.getElementById('modalPlayerName').value = playerName
        })
    </script>
}
