@model List<PlayerEnergyDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Enerji İzleme";
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-warning">
                            <i class="ki-duotone ki-electricity fs-2x text-warning"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Toplam Enerji</span>
                        <span class="fs-2 fw-bold mb-0">@(Model.Any() ? Model.Sum(x => x.CurrentEnergy) : 0)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-info border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-info">
                            <i class="ki-duotone ki-chart-line-4 fs-2x text-info"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Piller Dolu (90%+)</span>
                        <span class="fs-2 fw-bold mb-0 text-info">@Model.Count(x => x.MaxEnergy > 0 && (double)x.CurrentEnergy / x.MaxEnergy >= 0.9)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Oyuncu Enerji Durumları</span>
            <span class="text-muted mt-1 fw-bold fs-7">Tüm oyuncuların mevcut enerji ve dolum hızları</span>
        </h3>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                <thead>
                    <tr class="fw-bolder text-muted">
                        <th class="min-w-150px">Oyuncu Bilgisi</th>
                        <th class="min-w-140px">Enerji Seviyesi</th>
                        <th>Son Yenileme</th>
                        <th>Aktif Boost</th>
                        <th class="min-w-100px text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bolder text-hover-primary fs-6">@item.PlayerName</span>
                                    <span class="text-muted fw-bold fs-7">@item.PlayerId.ToString().Substring(0, 8)...</span>
                                </div>
                            </td>
                            <td>
                                @{
                                    var current = item.CurrentEnergy;
                                    var max = item.MaxEnergy > 0 ? item.MaxEnergy : 100;
                                    var percent = (current * 100 / max);
                                    if (percent > 100) percent = 100;
                                    var color = percent < 20 ? "danger" : (percent < 50 ? "warning" : "success");
                                }
                                <div class="d-flex align-items-center w-100">
                                    <div class="progress h-6px w-100 me-2 bg-light-@color">
                                        <div class="progress-bar bg-@color" role="progressbar" style="width: @percent%"></div>
                                    </div>
                                    <span class="text-muted fw-bold fs-7">@current/@max</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted fw-bold d-block fs-7">@item.LastRefillAt.ToLocalTime().ToString("g")</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ActiveBoostItem))
                                {
                                    <span class="badge badge-light-success fw-bold py-2 px-3 shadow-sm" data-bs-toggle="tooltip" 
                                          title="Bitiş: @item.BoostExpiresAt?.ToLocalTime().ToString("g")">
                                        <i class="ki-duotone ki-rocket fs-6 text-success me-1"></i> @item.ActiveBoostItem
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted fs-7">Aktif Yok</span>
                                }
                            </td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-icon btn-bg-light btn-active-color-primary js-refill-btn" 
                                        data-id="@item.PlayerId" data-name="@item.PlayerName">
                                    <i class="ki-duotone ki-plus-square fs-2"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-refill-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');

            Swal.fire({
                title: 'Enerji Ekle',
                text: `${name} için manuel enerji miktarı giriniz:`,
                input: 'number',
                inputAttributes: {
                    min: 1,
                    max: 100,
                    step: 1
                },
                inputValue: 10,
                showCancelButton: true,
                confirmButtonText: 'Ekle',
                cancelButtonText: 'Vazgeç',
                inputValidator: (value) => {
                    if (!value || value < 1) return 'Lütfen geçerli bir miktar giriniz!';
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/AdminEnergy/ManualRefill',
                        type: 'POST',
                        data: {
                            playerId: id,
                            amount: result.value,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Başarılı', 'Enerji eklendi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata', 'İşlem başarısız.', 'error');
                            }
                        }
                    });
                }
            });
        });

        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        });
    </script>
}
