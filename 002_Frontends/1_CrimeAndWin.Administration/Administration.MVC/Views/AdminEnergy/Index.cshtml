@model List<PlayerEnergyDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Enerji Yönetimi";
}

@Html.AntiForgeryToken()

<div class="row g-5 g-xl-10 mb-8 mt-5 justify-content-center">
    <div class="col-md-3">
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-success">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@(Model.Any() ? Model.Sum(x => x.CurrentEnergy) : 0)</span>
                        <span class="badge badge-light-success border border-success border-dashed fs-7 fw-bold px-3 py-1">Piller</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Sistemdeki Toplam Enerji</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5">
                <div class="d-flex align-items-center flex-column mt-3 w-100">
                    <div class="d-flex justify-content-between w-100 mt-auto mb-2">
                        <span class="fw-bold fs-6 text-dark opacity-50">Enerji Hacmi</span>
                        <span class="fw-bolder fs-6 text-dark opacity-75">100%</span>
                    </div>
                    <div class="h-8px mx-3 w-100 bg-white bg-opacity-50 rounded">
                        <div class="bg-success rounded h-8px" role="progressbar" style="width: 100%;" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-primary">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@Model.Count(x => x.MaxEnergy > 0 && (double)x.CurrentEnergy / x.MaxEnergy >= 0.9)</span>
                        <span class="badge badge-light-primary border border-primary border-dashed fs-7 fw-bold px-3 py-1">Aktif</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Dolu Enerjiye Sahip Oyuncular</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5">
                <div class="d-flex align-items-center flex-column mt-3 w-100">
                    <div class="symbol symbol-35px me-2 text-primary">
                        <i class="ki-duotone ki-zap fs-2hx"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8 shadow-sm">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Oyuncu Enerji Takip Çizelgesi</span>
            <span class="text-muted mt-1 fw-bold fs-7">Tüm sunucudaki enerji tüketim ve yenilenme verileri</span>
        </h3>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-4">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th class="ps-4 rounded-start min-w-150px">Oyuncu Bilgisi</th>
                        <th class="min-w-200px text-center">Enerji Seviyesi (%)</th>
                        <th class="text-center">Son Yenileme</th>
                        <th class="text-center">Aktif Boost</th>
                        <th class="min-w-100px text-end pe-4 rounded-end">Hızlı İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-35px me-3">
                                        <span class="symbol-label bg-light-warning text-warning fw-bold">@item.PlayerName[0]</span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bold text-hover-primary mb-1 fs-6">@item.PlayerName</span>
                                        <span class="text-muted fw-semi-bold fs-8">ID: @item.PlayerId.ToString().Substring(0, 8)</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @{
                                    var current = item.CurrentEnergy;
                                    var max = item.MaxEnergy > 0 ? item.MaxEnergy : 100;
                                    var percent = (current * 100 / max);
                                    if (percent > 100) percent = 100;
                                    var color = percent < 20 ? "danger" : (percent < 50 ? "warning" : "success");
                                }
                                <div class="d-flex flex-column w-100 me-2">
                                    <div class="d-flex flex-stack mb-2 text-dark fw-bold fs-8">
                                        <span>@current / @max</span>
                                        <span>%@percent</span>
                                    </div>
                                    <div class="h-6px w-100 bg-light-@color rounded">
                                        <div class="bg-@color rounded h-6px" role="progressbar" style="width: @percent%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="text-muted fw-bold d-block fs-8">@item.LastRefillAt.ToLocalTime().ToString("g")</span>
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.ActiveBoostItem))
                                {
                                    <span class="badge badge-light-success border border-success border-dashed fw-bold fs-8 px-3 py-2" data-bs-toggle="tooltip" 
                                          title="Bitiş: @item.BoostExpiresAt?.ToLocalTime().ToString("g")">
                                        <i class="ki-duotone ki-rocket fs-7 text-success me-1"></i> @item.ActiveBoostItem
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted fs-8">Aktif Boost Yok</span>
                                }
                                                      <td class="text-end pe-4">
                                <button type="button" class="btn btn-icon btn-light-warning btn-active-warning btn-sm shadow-sm js-refill-btn" 
                                        data-id="@item.PlayerId" data-name="@item.PlayerName"
                                        data-bs-toggle="tooltip" title="Enerji Ver">
                                    <i class="ki-duotone ki-zap fs-2"><span class="path1"></span><span class="path2"></span></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-refill-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');
            const token = $('input[name="__RequestVerificationToken"]').val();

            Swal.fire({
                title: 'Hızlı Enerji Takviyesi',
                text: `${name} için eklenecek enerji miktarını belirleyin:`,
                input: 'number',
                icon: 'question',
                inputAttributes: {
                    min: 1,
                    max: 100,
                    step: 1
                },
                inputValue: 10,
                showCancelButton: true,
                confirmButtonText: 'Enerji Ver',
                cancelButtonText: 'Vazgeç',
                buttonsStyling: false,
                customClass: {
                    confirmButton: 'btn btn-warning',
                    cancelButton: 'btn btn-active-light'
                },
                inputValidator: (value) => {
                    if (!value || value < 1) return 'Lütfen geçerli bir miktar giriniz!';
                },
                showLoaderOnConfirm: true,
                preConfirm: (amount) => {
                    return $.ajax({
                        url: '@Url.Action("ManualRefill", "AdminEnergy")',
                        type: 'POST',
                        data: {
                            playerId: id,
                            amount: amount,
                            __RequestVerificationToken: token
                        }
                    }).then(response => {
                        if (!response.success) {
                            throw new Error(response.message || 'Bir hata oluştu');
                        }
                        return response;
                    }).catch(error => {
                        Swal.showValidationMessage(`İşlem başarısız: ${error.message}`);
                    });
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Başarılı!',
                        text: result.value.message || 'Enerji başarıyla eklendi.',
                        icon: 'success',
                        confirmButtonText: 'Tamam',
                        customClass: { confirmButton: 'btn btn-primary' }
                    }).then(() => location.reload());
                }
            });
        });

        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        });
    </script>
}
