@model List<ActiveBoostDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Aktif Item Boostları";
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-primary">
                            <i class="ki-duotone ki-rocket fs-2x text-primary"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Aktif Boost</span>
                        <span class="fs-2 fw-bold mb-0">@(Model?.Count ?? 0)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-danger border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-danger">
                            <i class="ki-duotone ki-time fs-2x text-danger"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Bitecek ( < 1 Dakika )</span>
                        <span class="fs-2 fw-bold mb-0 text-danger">
                            @(Model?.Count(x => (x.BoostExpiresAt - DateTime.UtcNow).TotalSeconds < 60) ?? 0)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Aktif Item Boostları</span>
            <span class="text-muted mt-1 fw-bold fs-7">Oyuncuların kullandığı aktif güçlendiriciler</span>
        </h3>
    </div>
    <div class="card-body py-3">
        @if (Model == null || !Model.Any())
        {
            <div class="notice d-flex bg-light-info rounded border-info border border-dashed p-6">
                <i class="ki-duotone ki-information-5 fs-2tx text-info me-4"></i>
                <div class="d-flex flex-stack flex-grow-1">
                    <div class="fw-bold">
                        <h4 class="text-gray-900 fw-bolder">Boost Kaydı Yok</h4>
                        <div class="fs-6 text-gray-700">Şu an sistemde aktif olarak kullanılan bir boost bulunmamaktadır.</div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                    <thead>
                        <tr class="fw-bolder text-muted">
                            <th class="min-w-150px">Oyuncu Bilgisi</th>
                            <th>Boost Item / Tip</th>
                            <th>Bitiş Zamanı (Yerel)</th>
                            <th>Kalan Süre</th>
                            <th class="min-w-100px text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var remainingSeconds = (item.BoostExpiresAt - DateTime.UtcNow).TotalSeconds;
                            if (remainingSeconds < 0) remainingSeconds = 0;
                            
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bolder text-hover-primary fs-6">@item.PlayerName</span>
                                        <span class="text-muted fw-bold fs-7">@item.PlayerId.ToString().Substring(0, 8)...</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-light-primary fw-bold px-3 py-2">
                                        <i class="ki-duotone ki-abstract-26 fs-6 text-primary me-2"></i> @item.BoostItem
                                    </span>
                                </td>
                                <td>
                                    <span class="text-muted fw-bold d-block fs-7">@item.BoostExpiresAt.ToLocalTime().ToString("g")</span>
                                </td>
                                <td>
                                    @{
                                        var minutes = (int)remainingSeconds / 60;
                                        var seconds = (int)remainingSeconds % 60;
                                        var badgeColor = remainingSeconds < 60 ? "warning" : "success";
                                    }
                                    <span class="badge badge-light-@badgeColor fs-7 fw-bolder">
                                        <i class="ki-duotone ki-watch fs-6 text-@badgeColor me-1"></i> @minutes.ToString("D2"):@seconds.ToString("D2")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-light-danger fw-bolder js-revoke-btn" 
                                            data-id="@item.PlayerId" data-name="@item.PlayerName" data-item="@item.BoostItem">
                                        <i class="ki-duotone ki-cross-circle fs-3 me-1"></i> İptal Et
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-revoke-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');
            const boost = $(this).data('item');

            Swal.fire({
                title: 'Boost İptal Edilsin mi?',
                text: `${name} oyuncusunun ${boost} etkisini iptal etmek istediğinize emin misiniz?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, İptal Et!',
                cancelButtonText: 'Vazgeç',
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/AdminBoost/Revoke',
                        type: 'POST',
                        data: {
                            playerId: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('İptal Edildi!', 'Boost etkisi kaldırıldı.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', 'İşlem sırasında bir hata oluştu.', 'error');
                            }
                        }
                    });
                }
            });
        });
    </script>
}
