@model List<ResultModerationActionVM>

@{
    Layout = "_AdminLayout";
    var total = Model.Count;
    var active = Model.Count(x => x.IsActive);
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Toplam Action</h5>
                <p class="fs-2 fw-bold mb-0">@total</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Active</h5>
                <p class="fs-2 fw-bold mb-0">@active</p>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Moderation Actions</span>
            <span class="text-muted mt-1 fw-bold fs-7">@Model.Count kayıt</span>
        </h3>

        <div class="card-toolbar d-flex align-items-center gap-3">
            <span class="text-muted fw-semibold fs-7">create →</span>
            <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary"
                    data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                <span class="svg-icon svg-icon-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" viewBox="0 0 24 24">
                        <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                            <rect x="5" y="5" width="5" height="5" rx="1" fill="currentColor" />
                            <rect x="14" y="5" width="5" height="5" rx="1" fill="currentColor" opacity="0.3" />
                            <rect x="5" y="14" width="5" height="5" rx="1" fill="currentColor" opacity="0.3" />
                            <rect x="14" y="14" width="5" height="5" rx="1" fill="currentColor" opacity="0.3" />
                        </g>
                    </svg>
                </span>
            </button>

            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-bold w-225px"
                 data-kt-menu="true">
                <div class="menu-item px-3">
                    <div class="menu-content fs-6 text-dark fw-bolder px-3 py-4">Quick Actions</div>
                </div>
                <div class="separator mb-3 opacity-75"></div>
                <div class="menu-item px-3 pb-3">
                    <a class="menu-link px-3" asp-action="CreateModerationAction" asp-controller="AdminModeration">Yeni Action</a>
                </div>
                <div class="menu-item px-3 pb-3">
                    <a class="menu-link px-3" asp-action="Reports" asp-controller="AdminModeration">Reports</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                <thead>
                    <tr class="fw-bolder text-muted">
                        <th>Id</th>
                        <th>Player</th>
                        <th>Type</th>
                        <th>Reason</th>
                        <th>ActionDate</th>
                        <th>Expiry</th>
                        <th>Active</th>
                        <th class="min-w-100px text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@(item.PlayerDisplay ?? item.PlayerId.ToString())</td>
                            <td class="fw-bold">@item.ActionType</td>
                            <td>@item.Reason</td>
                            <td>@item.ActionDateUtc.ToString("g")</td>
                            <td>@(item.ExpiryDateUtc?.ToString("g") ?? "-")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-light-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge badge-light-secondary">No</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="EditModerationAction" asp-controller="AdminModeration" asp-route-id="@item.Id"
                                   class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                    <span class="svg-icon svg-icon-3">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <path opacity="0.3" d="M21.4 8.35303L19.241 10.511L13.485 4.755L15.643 2.59595C16.0248 2.21423 16.5426 1.99988 17.0825 1.99988C17.6224 1.99988 18.1402 2.21423 18.522 2.59595L21.4 5.474C21.7817 5.85581 21.9962 6.37355 21.9962 6.91345C21.9962 7.45335 21.7817 7.97122 21.4 8.35303ZM3.68699 21.932L9.88699 19.865L4.13099 14.109L2.06399 20.309C1.98815 20.5354 1.97703 20.7787 2.03189 21.0111C2.08674 21.2436 2.2054 21.4561 2.37449 21.6248C2.54359 21.7934 2.75641 21.9115 2.989 21.9658C3.22158 22.0201 3.4647 22.0084 3.69099 21.932H3.68699Z" fill="currentColor" />
                                            <path d="M5.574 21.3L3.692 21.928C3.46591 22.0032 3.22334 22.0141 2.99144 21.9594C2.75954 21.9046 2.54744 21.7864 2.3789 21.6179C2.21036 21.4495 2.09202 21.2375 2.03711 21.0056C1.9822 20.7737 1.99289 20.5312 2.06799 20.3051L2.696 18.422L5.574 21.3ZM4.13499 14.105L9.891 19.861L19.245 10.507L13.489 4.75098L4.13499 14.105Z" fill="currentColor" />
                                        </svg>
                                    </span>
                                </a>

                                <form class="d-inline js-delete-action-form" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm">
                                        <span class="svg-icon svg-icon-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                                <path d="M5 9C5 8.44772 5.44772 8 6 8H18C18.5523 8 19 8.44772 19 9V18C19 19.6569 17.6569 21 16 21H8C6.34315 21 5 19.6569 5 18V9Z" fill="currentColor" />
                                                <path opacity="0.5" d="M5 5C5 4.44772 5.44772 4 6 4H18C18.5523 4 19 4.44772 19 5V5C19 5.55228 18.5523 6 18 6H6C5.44772 6 5 5.55228 5 5V5Z" fill="currentColor" />
                                                <path opacity="0.5" d="M9 4C9 3.44772 9.44772 3 10 3H14C14.5523 3 15 3.44772 15 4V4H9V4Z" fill="currentColor" />
                                            </svg>
                                        </span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            document.querySelectorAll('.js-delete-action-form').forEach(f => {
                f.addEventListener('submit', function (e) {
                    e.preventDefault();
                    if (!confirm('Bu moderation action kaydını silmek istediğinize emin misiniz?')) return;

                    fetch('@Url.Action("DeleteModerationAction", "AdminModeration")', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => r.json())
                    .then(res => { if (res.success) location.reload(); else alert('Silme sırasında hata oluştu.'); })
                    .catch(() => alert('Silme sırasında hata oluştu.'));
                });
            });
        })();
    </script>
}