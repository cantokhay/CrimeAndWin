@model UpdateReportVM
@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Report Düzenle</h3>
        <a asp-action="Reports" asp-controller="AdminModeration" class="btn btn-sm btn-light">Listeye Dön</a>
    </div>

    <div class="card-body">
        <form asp-action="EditReport" asp-controller="AdminModeration" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Reporter</label>
                    <select asp-for="ReporterId" asp-items="Model.PlayerOptions" class="form-select"></select>
                    <span asp-validation-for="ReporterId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Reported Player</label>
                    <select asp-for="ReportedPlayerId" asp-items="Model.PlayerOptions" class="form-select"></select>
                    <span asp-validation-for="ReportedPlayerId" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Reason</label>
                    <input asp-for="Reason" class="form-control" />
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" asp-for="IsResolved" type="checkbox" />
                        <label class="form-check-label">Resolved</label>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Resolved At (UTC)</label>
                    <input asp-for="ResolvedAtUtc" class="form-control" type="datetime-local" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Resolved By ModeratorId (Guid)</label>
                    <input asp-for="ResolvedByModeratorId" class="form-control" placeholder="00000000-0000-0000-0000-000000000000" />
                </div>
            </div>

            <div class="mt-4">
                <button class="btn btn-primary" type="submit">Güncelle</button>
                <a asp-action="Reports" asp-controller="AdminModeration" class="btn btn-light ms-2">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
