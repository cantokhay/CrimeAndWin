@model List<ResultLeaderboardEntryVM>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sıralama Kayıtları";
}

@Html.AntiForgeryToken()

<div class="row g-5 g-xl-10 mb-8 mt-5">
    <div class="col-md-4">
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-success text-success">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@Model.Count</span>
                        <span class="badge badge-light-success border border-success border-dashed fs-7 fw-bold px-3 py-1">Kayıt</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Sistemdeki Toplam Skor Verisi</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5">
                <i class="ki-duotone ki-medal-star fs-3x"></i>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8 shadow-sm">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Skor ve Pozisyon Kayıtları</span>
            <span class="text-muted mt-1 fw-bold fs-7">Oyuncuların tablolardaki anlık başarı ve sıralama değerleri</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateEntry" class="btn btn-sm btn-primary">
                <i class="ki-duotone ki-plus fs-2 me-1"></i> Manuel Skor Ekle
            </a>
        </div>
    </div>

    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-4">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th class="ps-4 rounded-start min-w-150px">Oyuncu Bilgisi</th>
                        <th>Liderlik Tablosu</th>
                        <th class="text-center">Puan / Skor</th>
                        <th class="text-center">Sıra</th>
                        <th class="text-center">Durum</th>
                        <th class="text-center">Tarih</th>
                        <th class="min-w-100px text-end pe-4 rounded-end">Yönetim</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-35px me-3">
                                        <span class="symbol-label bg-light-primary text-primary fw-bold">@item.PlayerDisplay?[0]</span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bold text-hover-primary mb-1 fs-6">@(item.PlayerDisplay ?? "Bilinmeyen")</span>
                                        <span class="text-muted fs-8">Ref: #@item.Id.ToString().Substring(0, 8)</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-gray-700 fw-bold fs-7">@(item.LeaderboardDisplay ?? "Genel Sıralama")</span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-light-primary border border-primary border-dashed fs-7 fw-bold px-3 py-1">@item.RankPoints.ToString("N0")</span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-light-dark fw-bold">#@item.Position</span>
                            </td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-light-success fw-bold">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge badge-light-danger fw-bold">Pasif</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="text-muted fw-bold d-block fs-8">@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="EditEntry" asp-route-id="@item.Id" 
                                   class="btn btn-icon btn-light-primary btn-active-primary btn-sm me-2 shadow-sm">
                                    <i class="ki-duotone ki-pencil fs-3"></i>
                                </a>
                                <button type="button" class="btn btn-icon btn-light-danger btn-active-danger btn-sm shadow-sm js-delete-entry-btn" 
                                        data-id="@item.Id" data-name="@item.PlayerDisplay">
                                    <i class="ki-duotone ki-trash fs-3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-entry-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name') || "Seçili kayıt";
            const token = $('input[name="__RequestVerificationToken"]').val();

            Swal.fire({
                title: 'Kaydı Sil?',
                text: `"${name}" oyuncusuna ait bu sıralama verisini kalıcı olarak silmek istediğinize emin misiniz?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                },
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return $.ajax({
                        url: '@Url.Action("DeleteEntry", "AdminLeadership")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: token
                        }
                    }).then(response => {
                        if (!response.success) {
                            throw new Error(response.message || 'Silme işlemi başarısız');
                        }
                        return response;
                    }).catch(error => {
                        Swal.showValidationMessage(`Hata: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Silindi!',
                        text: 'Sıralama kaydı başarıyla kaldırıldı.',
                        icon: 'success',
                        customClass: { confirmButton: 'btn btn-primary' }
                    }).then(() => location.reload());
                }
            });
        });
    </script>
}