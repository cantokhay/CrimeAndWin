@model List<ResultLeaderboardVM>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liderlik Tabloları";
}

@Html.AntiForgeryToken()

<div class="row g-5 g-xl-10 mb-8 mt-5">
    <div class="col-md-4">
        <div class="card card-flush h-md-100 shadow-sm border-0 bg-light-warning text-warning">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@Model.Count</span>
                        <span class="badge badge-light-warning border border-warning border-dashed fs-7 fw-bold px-3 py-1">Tablo</span>
                    </div>
                    <span class="text-gray-600 pt-1 fw-bold fs-6">Aktif Sıralama Sistemi</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-5">
                <i class="ki-duotone ki-chart-line-star fs-3x"></i>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8 shadow-sm">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Sıralama Yönetimi</span>
            <span class="text-muted mt-1 fw-bold fs-7">Rekabetçi oyun modları ve sezonluk liderlik tabloları</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateLeaderboard" class="btn btn-sm btn-warning">
                <i class="ki-duotone ki-plus fs-2 me-1"></i> Yeni Sıralama Ekle
            </a>
        </div>
    </div>

    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-4">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th class="ps-4 rounded-start min-w-150px">Tablo Tanımı</th>
                        <th>Açıklama</th>
                        <th class="text-center">Kapsam</th>
                        <th class="text-center">Dünya / Sezon</th>
                        <th class="text-center">Oluşturulma</th>
                        <th class="min-w-100px text-end pe-4 rounded-end">Yönetim</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-35px me-3">
                                        <span class="symbol-label bg-light-warning text-warning fw-bold">LB</span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-bold text-hover-primary mb-1 fs-6">@item.Name</span>
                                        <span class="text-muted fs-8">Ref: #@item.Id.ToString().Substring(0, 8)</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-gray-600 fw-semi-bold d-block fs-7">@item.Description</span>
                            </td>
                            <td class="text-center">
                                @if (item.IsSeasonal)
                                {
                                    <span class="badge badge-light-success border border-success border-dashed fw-bold">Sezonluk</span>
                                }
                                else
                                {
                                    <span class="badge badge-light-primary border border-primary border-dashed fw-bold">Global</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex flex-column align-items-center">
                                    <span class="badge badge-light-dark fw-bold fs-9 mb-1">W: @(item.GameWorldId?.ToString().Substring(0, 8) ?? "N/A")</span>
                                    <span class="badge badge-light-info fw-bold fs-9">S: @(item.SeasonId?.ToString().Substring(0, 8) ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="text-muted fw-bold d-block fs-8">@item.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="EditLeaderboard" asp-route-id="@item.Id" 
                                   class="btn btn-icon btn-light-warning btn-active-warning btn-sm me-2 shadow-sm"
                                   data-bs-toggle="tooltip" title="Düzenle">
                                    <i class="ki-duotone ki-pencil fs-3"><span class="path1"></span><span class="path2"></span></i>
                                </a>
                                <button type="button" class="btn btn-icon btn-light-danger btn-active-danger btn-sm shadow-sm js-delete-leaderboard-btn" 
                                        data-id="@item.Id" data-name="@item.Name"
                                        data-bs-toggle="tooltip" title="Sil">
                                    <i class="ki-duotone ki-trash fs-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-leaderboard-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');
            const token = $('input[name="__RequestVerificationToken"]').val();

            Swal.fire({
                title: 'Tabloyu Sil?',
                text: `"${name}" sıralamasını ve tüm ilişkili verileri silmek istediğinize emin misiniz?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                },
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return $.ajax({
                        url: '@Url.Action("DeleteLeaderboard", "AdminLeadership")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: token
                        }
                    }).then(response => {
                        if (!response.success) {
                            throw new Error(response.message || 'Silme işlemi başarısız');
                        }
                        return response;
                    }).catch(error => {
                        Swal.showValidationMessage(`Hata: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Silindi!',
                        text: 'Liderlik tablosu başarıyla kaldırıldı.',
                        icon: 'success',
                        customClass: { confirmButton: 'btn btn-primary' }
                    }).then(() => location.reload());
                }
            });
        });
    </script>
}