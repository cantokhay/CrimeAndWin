@model UpdateLeaderboardVM

@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Leaderboard Düzenle</h3>
        <a asp-action="Leaderboards" asp-controller="AdminLeadership" class="btn btn-sm btn-light">Listeye Dön</a>
    </div>

    <div class="card-body">
        <form asp-action="EditLeaderboard" asp-controller="AdminLeadership" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">IsSeasonal</label>
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsSeasonal" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Seasonal</label>
                    </div>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <select id="gameWorldSelect" asp-for="GameWorldId" asp-items="Model.GameWorldOptions" class="form-select">
                    <option value="">-- GameWorld seç --</option>
                </select>

                <select id="seasonSelect" asp-for="SeasonId" asp-items="Model.SeasonOptions" class="form-select">
                    <option value="">-- Season seç --</option>
                </select>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Güncelle</button>
                <a asp-action="Leaderboards" asp-controller="AdminLeadership" class="btn btn-light ms-2">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const gw = document.getElementById('gameWorldSelect');
            const season = document.getElementById('seasonSelect');

            if (!gw || !season) {
                console.warn('gameWorldSelect / seasonSelect bulunamadı. View idlerini kontrol et.');
                return;
            }

            function escapeHtml(str) {
                if (str === null || str === undefined) return '';
                return String(str)
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#039;');
            }

            async function fetchJson(url) {
                const res = await fetch(url, { headers: { 'Accept': 'application/json' } });

                if (!res.ok) {
                    const text = await res.text().catch(() => '');
                    throw new Error(`HTTP ${res.status} ${res.statusText} | ${text}`);
                }

                return await res.json();
            }

            function setSeasonOptions(list, selectedId) {
                // her durumda placeholder koy
                let html = `<option value="">-- Season seç --</option>`;

                if (!Array.isArray(list) || list.length === 0) {
                    html += `<option value="" disabled>(Bu GameWorld için season yok)</option>`;
                    season.innerHTML = html;
                    season.disabled = false;
                    return;
                }

                html += list.map(x => {
                    const idStr = String(x.id ?? '');
                    const isSelected = selectedId && String(selectedId).toLowerCase() === idStr.toLowerCase();
                    return `<option value="${escapeHtml(idStr)}"${isSelected ? ' selected' : ''}>${escapeHtml(x.text ?? '')}</option>`;
                }).join('');

                season.innerHTML = html;
                season.disabled = false;
            }

            async function loadSeasons(gameWorldId, selectedSeasonId) {
                season.disabled = true;
                season.innerHTML = `<option value="">-- Yükleniyor... --</option>`;

                if (!gameWorldId) {
                    season.innerHTML = `<option value="">-- Season seç --</option>`;
                    season.disabled = false;
                    return;
                }

                try {
                    const url = `@Url.Action("GetSeasonsByGameWorld", "AdminLeadership")?gameWorldId=${encodeURIComponent(gameWorldId)}`;
                    console.log('Loading seasons:', url);

                    const list = await fetchJson(url);
                    console.log('Seasons response:', list);

                    setSeasonOptions(list, selectedSeasonId);
                } catch (e) {
                    console.error('Season load error:', e);

                    season.disabled = false;
                    season.innerHTML =
                        `<option value="">-- Season yüklenemedi --</option>` +
                        `<option value="" disabled>${escapeHtml(e.message)}</option>`;
                }
            }

            // İlk açılış (Edit sayfasında GameWorld doluysa sezonları ona göre çek)
            loadSeasons(gw.value, season.value);

            // GameWorld değişince Seasonları yeniden çek
            gw.addEventListener('change', function () {
                // GameWorld değiştiğinde Season seçimini sıfırla
                loadSeasons(this.value, null);
            });
        })();
    </script>
}