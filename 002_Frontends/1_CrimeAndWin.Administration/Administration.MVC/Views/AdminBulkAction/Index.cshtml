@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Toplu İşlem Merkezi";
}

@Html.AntiForgeryToken()

<div class="card mb-5 mb-xl-10 shadow-sm border-0">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Sistem Genel Toplu İşlemler</span>
            <span class="text-muted mt-1 fw-bold fs-7">Tüm oyuncuları veya sistemi etkileyecek yüksek yetkili operasyonlar</span>
        </h3>
    </div>
    <div class="card-body py-8">
        <div class="row g-5 g-xl-10">
            <!-- Reset Energy -->
            <div class="col-md-4">
                <div class="card border border-dashed border-gray-300 p-6 text-center h-100 hover-elevate-up shadow-sm">
                    <div class="symbol symbol-60px mb-5">
                        <span class="symbol-label bg-light-success text-success">
                            <i class="ki-duotone ki-flash-circle fs-2x"></i>
                        </span>
                    </div>
                    <h3 class="fs-4 fw-bold mb-3 text-dark">Tüm Enerjileri Yenile</h3>
                    <p class="text-gray-500 fs-7 mb-6">Sistemdeki tüm aktif oyuncuların enerjisini maksimum kapasiteye (100) çıkarır.</p>
                    <button type="button" class="btn btn-light-success btn-sm w-100 js-bulk-action" 
                            data-url="@Url.Action("ResetAllEnergy", "AdminBulkAction")" 
                            data-message="Tüm oyuncuların enerjisi yenilenecek. Bu işlem geri alınamaz. Devam edilsin mi?">
                        Uygulamayı Başlat
                    </button>
                </div>
            </div>

            <!-- Clear Cooldowns -->
            <div class="col-md-4">
                <div class="card border border-dashed border-gray-300 p-6 text-center h-100 hover-elevate-up shadow-sm">
                    <div class="symbol symbol-60px mb-5">
                        <span class="symbol-label bg-light-primary text-primary">
                            <i class="ki-duotone ki-timer fs-2x"></i>
                        </span>
                    </div>
                    <h3 class="fs-4 fw-bold mb-3 text-dark">Tüm Cooldownları Sıfırla</h3>
                    <p class="text-gray-500 fs-7 mb-6">Bekleyen tüm aksiyon sürelerini anında sonlandırır ve oyuncuları serbest bırakır.</p>
                    <button type="button" class="btn btn-light-primary btn-sm w-100 js-bulk-action" 
                            data-url="@Url.Action("ClearAllCooldowns", "AdminBulkAction")" 
                            data-message="Tüm bekleme süreleri sıfırlanacak. Oyuncular hemen aksiyon alabilir hale gelecek. Devam edilsin mi?">
                        Uygulamayı Başlat
                    </button>
                </div>
            </div>

            <!-- Approve All Users -->
            <div class="col-md-4">
                <div class="card border border-dashed border-gray-300 p-6 text-center h-100 hover-elevate-up shadow-sm">
                    <div class="symbol symbol-60px mb-5">
                        <span class="symbol-label bg-light-warning text-warning">
                            <i class="ki-duotone ki-profile-user fs-2x"></i>
                        </span>
                    </div>
                    <h3 class="fs-4 fw-bold mb-3 text-dark">Bekleyen Kayıtları Onayla</h3>
                    <p class="text-gray-500 fs-7 mb-6">Kayıt olmuş ancak henüz onaylanmamış tüm oyuncuları tek tıkla sisteme kabul edin.</p>
                    <button type="button" class="btn btn-light-warning btn-sm w-100 js-bulk-action" 
                            data-url="@Url.Action("ApproveAllPendingUsers", "AdminBulkAction")" 
                            data-message="Tüm bekleyen kullanıcılar onaylanacak ve oyuna girebilecekler. Devam edilsin mi?">
                        Uygulamayı Başlat
                    </button>
                </div>
            </div>
        </div>

        <div class="alert alert-dismissible bg-light-danger d-flex flex-center flex-column py-10 px-10 px-lg-20 mt-15 border border-danger border-dashed rounded-3">
            <i class="ki-duotone ki-information-5 fs-5tx text-danger mb-5"></i>
            <div class="text-center">
                <h1 class="fw-bold mb-5 text-danger">KRİTİK UYARI: YÜKSEK ETKİLİ İŞLEMLER</h1>
                <div class="separator separator-dashed border-danger opacity-25 mb-5"></div>
                <div class="mb-5 text-dark-50 fs-6 fw-semi-bold">
                    Buradaki operasyonlar tüm oyuncu veritabanını anlık olarak günceller. 
                    <br/>Lütfen bu paneli sadece yetkili personel eşliğinde veya acil durumlarda kullanın.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-bulk-action', function() {
            const url = $(this).data('url');
            const message = $(this).data('message');
            const token = $('input[name="__RequestVerificationToken"]').val();

            Swal.fire({
                title: "Emin misiniz?",
                text: message,
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Evet, Onaylıyorum!",
                cancelButtonText: "Vazgeç",
                showLoaderOnConfirm: true,
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                },
                preConfirm: () => {
                    return $.ajax({
                        url: url,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: token
                        }
                    }).then(response => {
                        if (!response.success) {
                            throw new Error(response.message || 'İşlem başarısız');
                        }
                        return response;
                    }).catch(error => {
                        Swal.showValidationMessage(`Hata: ${error.message || 'Bağlantı sorunu'}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: "Başarılı!",
                        text: result.value.message || "Toplu işlem başarıyla tamamlandı.",
                        icon: "success",
                        confirmButtonText: "Tamam",
                        customClass: {
                            confirmButton: "btn btn-primary"
                        }
                    }).then(() => {
                        location.reload();
                    });
                }
            });
        });
    </script>
}
