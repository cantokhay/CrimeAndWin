@model List<ResultPlayerActionAttemptVM>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Aksiyon Denemeleri";
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-primary">
                            <i class="ki-duotone ki-chart-line-star fs-2x text-primary"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Toplam Deneme</span>
                        <span class="fs-2 fw-bold mb-0">@Model.Count</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-success">
                            <i class="ki-duotone ki-check-circle fs-2x text-success"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Başarılı</span>
                        <span class="fs-2 fw-bold mb-0 text-success">@Model.Count(x => x.OutcomeType == "Success")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-danger border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-danger">
                            <i class="ki-duotone ki-cross-circle fs-2x text-danger"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Başarısız</span>
                        <span class="fs-2 fw-bold mb-0 text-danger">@Model.Count(x => x.OutcomeType == "Fail")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Oyuncu Aksiyon Denemeleri</span>
            <span class="text-muted mt-1 fw-bold fs-7">Son @Model.Count aksiyon kaydı</span>
        </h3>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                <thead>
                    <tr class="fw-bolder text-muted">
                        <th>Oyuncu / Aksiyon Kimliği</th>
                        <th>Başarı Oranı</th>
                        <th>Sonuç</th>
                        <th>Tarih</th>
                        <th class="min-w-100px text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bolder fs-6">Oyuncu: @item.PlayerId.ToString().Substring(0, 8)...</span>
                                    <span class="text-muted fw-bold fs-7">Aksiyon: @item.ActionDefinitionId.ToString().Substring(0, 8)...</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center w-100px">
                                    <div class="progress h-6px w-100 me-2 bg-light-success">
                                        @{
                                            var percent = (item.SuccessRate * 100).ToString("0");
                                        }
                                        <div class="progress-bar bg-success" role="progressbar" style="width: @percent%" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <span class="text-muted fw-bold">%@percent</span>
                                </div>
                            </td>
                            <td>
                                @if (item.OutcomeType == "Success")
                                {
                                    <span class="badge badge-light-success py-2 px-4 shadow-sm">
                                        <i class="ki-duotone ki-check fs-5 text-success me-1"></i> Başarılı
                                    </span>
                                }
                                else if (item.OutcomeType == "Fail")
                                {
                                    <span class="badge badge-light-danger py-2 px-4 shadow-sm">
                                        <i class="ki-duotone ki-cross fs-5 text-danger me-1"></i> Başarısız
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-light-warning py-2 px-4 shadow-sm">@item.OutcomeType</span>
                                }
                            </td>
                            <td>
                                <span class="text-muted fw-bold d-block fs-7">@item.CreatedAtUtc.ToString("g")</span>
                            </td>
                            <td class="text-end">
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm js-delete-btn" 
                                        data-id="@item.Id">
                                    <i class="ki-duotone ki-trash fs-3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-btn', function() {
            const id = $(this).data('id');

            Swal.fire({
                title: 'Kaydı Sil?',
                text: "Bu aksiyon denemesi kaydını silmek istediğinize emin misiniz?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/AdminAction/DeleteActionAttempt',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Silindi!', 'Kayıt başarıyla silindi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', 'Silme işlemi sırasında bir hata oluştu.', 'error');
                            }
                        }
                    });
                }
            });
        });
    </script>
}