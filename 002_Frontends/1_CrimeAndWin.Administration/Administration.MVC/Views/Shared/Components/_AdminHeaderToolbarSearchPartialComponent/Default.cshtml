<div class="d-flex align-items-stretch ms-1 ms-lg-3">
    <!--begin::Search-->
    <div id="kt_header_search" class="header-search d-flex align-items-stretch" 
         data-kt-search-keypress="true" 
         data-kt-search-min-length="2" 
         data-kt-search-enter="enter" 
         data-kt-search-layout="menu" 
         data-kt-menu-trigger="auto" 
         data-kt-menu-overflow="false" 
         data-kt-menu-permanent="true" 
         data-kt-menu-placement="bottom-end">

        <!--begin::Search toggle-->
        <div class="d-flex align-items-center" data-kt-search-element="toggle" id="kt_header_search_toggle">
            <div class="btn btn-icon btn-icon-muted btn-active-light btn-active-color-primary w-30px h-30px w-md-40px h-md-40px">
                <i class="ki-duotone ki-magnifier fs-1"></i>
            </div>
        </div>
        <!--end::Search toggle-->

        <!--begin::Menu-->
        <div data-kt-search-element="content" class="menu menu-sub menu-sub-dropdown p-7 w-325px w-md-375px">
            <!--begin::Wrapper-->
            <div data-kt-search-element="wrapper">
                <!--begin::Form-->
                <form data-kt-search-element="form" class="w-100 position-relative mb-3" autocomplete="off">
                    <i class="ki-duotone ki-magnifier fs-2 fs-lg-1 text-gray-500 position-absolute top-50 translate-middle-y ms-0"></i>
                    <input type="text" class="search-input form-control form-control-flush ps-10" name="search" value="" placeholder="Ara (Kullanıcı, Oyuncu, Aksiyon...)" data-kt-search-element="input" />
                    
                    <span class="position-absolute top-50 end-0 translate-middle-y lh-0 d-none me-1" data-kt-search-element="spinner">
                        <span class="spinner-border h-15px w-15px align-middle text-gray-400"></span>
                    </span>

                    <span class="btn btn-flush btn-active-color-primary position-absolute top-50 end-0 translate-middle-y lh-0 d-none" data-kt-search-element="clear">
                        <i class="ki-duotone ki-cross fs-2 me-0"></i>
                    </span>
                </form>
                <!--end::Form-->

                <div class="separator border-gray-200 mb-6"></div>

                <!--begin::Results-->
                <div data-kt-search-element="results" class="d-none">
                    <div class="scroll-y mh-200px mh-lg-350px" id="admin_search_results_container">
                        <!-- Dynamic results will be injected here -->
                    </div>
                </div>
                <!--end::Results-->

                <!--begin::Empty-->
                <div data-kt-search-element="empty" class="text-center d-none">
                    <div class="pt-10 pb-10">
                        <i class="ki-duotone ki-search-list fs-4x opacity-50"></i>
                    </div>
                    <div class="pb-15 fw-bold">
                        <h3 class="text-gray-600 fs-5 mb-2">Sonuç bulunamadı</h3>
                        <div class="text-muted fs-7">Farklı bir anahtar kelime deneyin</div>
                    </div>
                </div>
                <!--end::Empty-->
            </div>
            <!--end::Wrapper-->
        </div>
        <!--end::Menu-->
    </div>
    <!--end::Search-->
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const element = document.querySelector('#kt_header_search');
        if (!element) return;

        const search = KTSearch.getInstance(element);
        const resultsElement = element.querySelector('#admin_search_results_container');
        const emptyElement = element.querySelector('[data-kt-search-element="empty"]');
        const contentElement = element.querySelector('[data-kt-search-element="results"]');

        search.on('kt.search.process', function(instance) {
            const query = instance.getQuery();
            
            if (query.length < 2) return;

            instance.showSpinner();

            fetch(`/AdminSearch/GlobalSearch?q=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    instance.hideSpinner();
                    
                    if (data.results && data.results.length > 0) {
                        let html = '';
                        // Group by category if needed, but let's do a simple list first
                        data.results.forEach(item => {
                            html += `
                                <a href="${item.url}" class="d-flex text-dark text-hover-primary align-items-center mb-5">
                                    <div class="symbol symbol-40px me-4">
                                        <span class="symbol-label bg-light-${item.badgeColor}">
                                            <i class="ki-duotone ki-${item.icon} fs-2 text-${item.badgeColor}"></i>
                                        </span>
                                    </div>
                                    <div class="d-flex flex-column justify-content-start fw-bold">
                                        <span class="fs-6 fw-bold">${item.title}</span>
                                        <span class="fs-7 fw-bold text-muted">${item.category} - ${item.description}</span>
                                    </div>
                                </a>
                            `;
                        });
                        resultsElement.innerHTML = html;
                        emptyElement.classList.add('d-none');
                        contentElement.classList.remove('d-none');
                    } else {
                        resultsElement.innerHTML = '';
                        emptyElement.classList.remove('d-none');
                        contentElement.classList.add('d-none');
                    }
                })
                .catch(() => {
                    instance.hideSpinner();
                    resultsElement.innerHTML = '';
                    emptyElement.classList.remove('d-none');
                    contentElement.classList.add('d-none');
                });
        });

        search.on('kt.search.clear', function() {
            resultsElement.innerHTML = '';
            contentElement.classList.add('d-none');
            emptyElement.classList.add('d-none');
        });
    });
</script>
