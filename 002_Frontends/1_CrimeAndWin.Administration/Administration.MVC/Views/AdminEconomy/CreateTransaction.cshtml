@model CreateTransactionVM

@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Yeni Transaction Oluştur</h3>

        <a asp-action="Transactions"
           asp-controller="AdminEconomy"
           class="btn btn-sm btn-light">
            Listeye Dön
        </a>
    </div>

    <div class="card-body">
        <form asp-action="CreateTransaction" asp-controller="AdminEconomy" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Wallet</label>
                    <select asp-for="WalletId" asp-items="Model.WalletOptions" class="form-select"></select>
                    <span asp-validation-for="WalletId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Amount</label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">CurrencyType</label>
                    <input asp-for="CurrencyType" class="form-control" />
                    <span asp-validation-for="CurrencyType" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">ReasonCode</label>
                    <input asp-for="ReasonCode" class="form-control" />
                    <span asp-validation-for="ReasonCode" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Transactions" asp-controller="AdminEconomy" class="btn btn-light ms-2">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}