@model List<Administration.MVC.ViewModels.AuctionVMs.AdminAuctionListVM>
@{
    ViewData["Title"] = " hale Yonetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card card-flush shadow-sm border-0">
    <div class="card-header pt-7">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark fs-3"> hale Borsas</span>
            <span class="text-gray-400 mt-1 fw-semibold fs-7">Sehir mǬlkleri ve lisanslar iin aktif ihaleler</span>
        </h3>
        <div class="card-toolbar">
            <button class="btn btn-sm btn-primary fw-bold" id="kt_new_auction_btn">
                <i class="ki-duotone ki-delivery-2 fs-2"></i> Yeni hale Baslat
            </button>
        </div>
    </div>
    <div class="card-body pt-5">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5">
                <thead>
                    <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-200px"> hale Kalemi</th>
                        <th class="min-w-100px text-end">BaYlangYc Fiyat</th>
                        <th class="min-w-100px text-end">Son Teklif</th>
                        <th class="min-w-150px">En YǬksek Teklif Sahibi</th>
                        <th class="min-w-120px text-end">Bitis ZamanY</th>
                        <th class="min-w-100px text-center">Durum</th>
                        <th class="text-end min-w-100px"> lemler</th>
                    </tr>
                </thead>
                <tbody class="fw-semibold text-gray-600">
                    @foreach (var auction in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-45px me-3">
                                        <div class="symbol-label bg-light-primary text-primary">
                                            <i class="ki-duotone ki-delivery-time fs-2x"></i>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <span class="text-dark fw-bold text-hover-primary fs-6">@auction.Title</span>
                                        <span class="text-muted fw-semibold d-block fs-8">ID: @auction.Id.ToString().Substring(0,8)</span>
                                    </div>
                                </div>
                            </td>
                            <td class="text-end">@auction.BasePrice.ToString("C0")</td>
                            <td class="text-end">
                                <span class="text-primary fw-bold fs-5">@auction.CurrentBid.ToString("C0")</span>
                            </td>
                            <td>
                                <div class="symbol-group symbol-hover mb-0">
                                   <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="@auction.HighestBidderName">
                                       <span class="symbol-label bg-light-info text-info fw-bold">@auction.HighestBidderName.Substring(0,1)</span>
                                   </div>
                                    <span class="ms-2">@auction.HighestBidderName</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="badge badge-light-secondary">@auction.EndsAt.ToString("HH:mm:ss")</div>
                            </td>
                            <td class="text-center">
                                @if(auction.IsFinished) {
                                    <span class="badge badge-light-danger">KAPAL</span>
                                } else {
                                    <span class="badge badge-light-success blink">AKT F</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-icon btn-bg-light btn-active-color-primary">
                                    <i class="ki-duotone ki-eye fs-2"></i>
                                </button>
                                <button class="btn btn-sm btn-icon btn-bg-light btn-active-color-danger">
                                    <i class="ki-duotone ki-cross fs-2"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .blink {
        animation: blink-animation 1s steps(5, start) infinite;
    }
    @@keyframes blink-animation {
        to { visibility: hidden; }
    }
</style>
