@model CreateNotificationVM
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Notification Oluştur</h3>
        <a asp-action="Notifications" asp-controller="AdminNotification" class="btn btn-sm btn-light">Listeye Dön</a>
    </div>

    <div class="card-body">
        <form asp-action="CreateNotification" asp-controller="AdminNotification" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-12">
                    <label class="form-label">Player</label>
                    <select asp-for="PlayerId" asp-items="Model.PlayerOptions" class="form-select"></select>
                    <span asp-validation-for="PlayerId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Type</label>
                    <select asp-for="Type" asp-items="Model.TypeOptions" class="form-select"></select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Message</label>
                    <textarea asp-for="Message" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Message" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Notifications" asp-controller="AdminNotification" class="btn btn-light ms-2">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}