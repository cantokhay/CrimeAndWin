@model UpdateGameWorldVM

@{
    Layout = "_AdminLayout";
    var returnUrl = Url.Action("EditGameWorld", "AdminGameWorld", new { id = Model.Id });
}

<div class="card mb-5">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">GameWorld Düzenle</h3>

        <a asp-action="GameWorlds"
           asp-controller="AdminGameWorld"
           class="btn btn-sm btn-light">
            Listeye Dön
        </a>
    </div>
    <div class="card-body">
        <form asp-action="EditGameWorld"
              asp-controller="AdminGameWorld"
              method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Ad</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Max Energy</label>
                    <input asp-for="MaxEnergy" type="number" class="form-control" />
                    <span asp-validation-for="MaxEnergy" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Regen Rate / saat</label>
                    <input asp-for="RegenRatePerHour" type="number" class="form-control" />
                    <span asp-validation-for="RegenRatePerHour" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Güncelle</button>
                <a asp-action="GameWorlds"
                   asp-controller="AdminGameWorld"
                   class="btn btn-light ms-2">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">İlgili Season Listesi</h3>

        <a asp-action="CreateSeason"
           asp-controller="AdminGameWorld"
           asp-route-gameWorldId="@Model.Id"
           asp-route-returnUrl="@returnUrl"
           class="btn btn-sm btn-primary">
            Yeni Season Ekle
        </a>
    </div>
    <div class="card-body">
        @if (Model.Seasons != null && Model.Seasons.Any())
        {
            <div class="table-responsive">
                <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                    <thead>
                        <tr class="fw-bolder text-muted">
                            <th>Sıra No</th>
                            <th>Season No</th>
                            <th>Başlangıç</th>
                            <th>Bitiş</th>
                            <th>Durum</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Seasons.Count; i++)
                        {
                            var season = Model.Seasons[i];

                            <tr>
                                <td>
                                    @(i + 1)
                                    <input type="hidden" value="@season.Id" />
                                </td>
                                <td>@season.SeasonNumber</td>
                                <td>@season.StartUtc.ToString("g")</td>
                                <td>@season.EndUtc.ToString("g")</td>
                                <td>
                                    @if (season.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="EditSeason"
                                       asp-controller="AdminGameWorld"
                                       asp-route-id="@season.Id"
                                       asp-route-returnUrl="@returnUrl"
                                       class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                        <span class="svg-icon svg-icon-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                 viewBox="0 0 24 24" fill="none">
                                                <path opacity="0.3"
                                                      d="M21.4 8.35303L19.241 10.511L13.485 4.755L15.643 2.59595C16.0248 2.21423 16.5426 1.99988 17.0825 1.99988C17.6224 1.99988 18.1402 2.21423 18.522 2.59595L21.4 5.474C21.7817 5.85581 21.9962 6.37355 21.9962 6.91345C21.9962 7.45335 21.7817 7.97122 21.4 8.35303Z"
                                                      fill="currentColor" />
                                                <path d="M5.574 21.3L3.692 21.928C3.46591 22.0032 3.22334 22.0141 2.99144 21.9594C2.75954 21.9046 2.54744 21.7864 2.3789 21.6179C2.21036 21.4495 2.09202 21.2375 2.03711 21.0056C1.9822 20.7737 1.99289 20.5312 2.06799 20.3051L2.696 18.422L5.574 21.3ZM4.13499 14.105L9.891 19.861L19.245 10.507L13.489 4.75098L4.13499 14.105Z"
                                                      fill="currentColor" />
                                            </svg>
                                        </span>
                                    </a>

                                    <form class="d-inline js-delete-season-form" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@season.Id" />
                                        <button type="submit" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm">
                                            <span class="svg-icon svg-icon-3">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                                    <path d="M5 9C5 8.44772 5.44772 8 6 8H18C18.5523 8 19 8.44772 19 9V18C19 19.6569 17.6569 21 16 21H8C6.34315 21 5 19.6569 5 18V9Z" fill="currentColor" />
                                                    <path opacity="0.5" d="M5 5C5 4.44772 5.44772 4 6 4H18C18.5523 4 19 4.44772 19 5V5C19 5.55228 18.5523 6 18 6H6C5.44772 6 5 5.55228 5 5V5Z" fill="currentColor" />
                                                    <path opacity="0.5" d="M9 4C9 3.44772 9.44772 3 10 3H14C14.5523 3 15 3.44772 15 4V4H9V4Z" fill="currentColor" />
                                                </svg>
                                            </span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-light-info mb-0">
                Bu GameWorld için henüz season kaydı bulunmuyor.
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            document.querySelectorAll('.js-delete-season-form')
                .forEach(form => {
                    form.addEventListener('submit', function (e) {
                        e.preventDefault();

                        if (!confirm('Bu season kaydını silmek istediğinize emin misiniz?')) return;

                        const formData = new FormData(this);

                        fetch('@Url.Action("DeleteSeason", "AdminGameWorld")', {
                            method: 'POST',
                            body: formData
                        })
                        .then(r => r.json())
                        .then(res => {
                            if (res.success) {
                                location.reload();
                            } else {
                                alert('Silme sırasında hata oluştu.');
                            }
                        });
                    });
                });
        })();
    </script>
}