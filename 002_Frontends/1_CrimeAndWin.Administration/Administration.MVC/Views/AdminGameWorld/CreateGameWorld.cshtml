@model CreateGameWorldVM

@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Yeni GameWorld Oluştur</h3>

        <a asp-action="GameWorlds"
           asp-controller="AdminGameWorld"
           class="btn btn-sm btn-light">
            Listeye Dön
        </a>
    </div>
    <div class="card-body">
        <form asp-action="CreateGameWorld"
              asp-controller="AdminGameWorld"
              method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Ad</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Max Energy</label>
                    <input asp-for="MaxEnergy" type="number" class="form-control" />
                    <span asp-validation-for="MaxEnergy" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Regen Rate / saat</label>
                    <input asp-for="RegenRatePerHour" type="number" class="form-control" />
                    <span asp-validation-for="RegenRatePerHour" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="GameWorlds"
                   asp-controller="AdminGameWorld"
                   class="btn btn-light ms-2">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}