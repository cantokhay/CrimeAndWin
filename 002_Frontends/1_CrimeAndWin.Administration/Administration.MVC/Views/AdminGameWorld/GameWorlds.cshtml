@model List<ResultGameWorldVM>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Oyun Dünyaları (Game Worlds)";

    var totalSeasons = Model.Sum(x => x.SeasonsCount);
    var avgMaxEnergy = Model.Any() ? (int)Model.Average(x => x.MaxEnergy) : 0;
}

<div class="row mb-5 justify-content-center">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-primary">
                            <i class="ki-duotone ki-global fs-2x text-primary"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Toplam Dünya</span>
                        <span class="fs-2 fw-bold mb-0">@Model.Count</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-success">
                            <i class="ki-duotone ki-calendar-8 fs-2x text-success"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Toplam Sezon</span>
                        <span class="fs-2 fw-bold mb-0 text-success">@totalSeasons</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-45px me-5">
                        <span class="symbol-label bg-light-warning">
                            <i class="ki-duotone ki-flash-circle fs-2x text-warning"></i>
                        </span>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted fw-bold">Ortalama Enerji</span>
                        <span class="fs-2 fw-bold mb-0 text-warning">@avgMaxEnergy</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bolder fs-3 mb-1">Oyun Dünyaları</span>
            <span class="text-muted mt-1 fw-bold fs-7">Sistemdeki temel oyun sunucuları ve kuralları</span>
        </h3>
        <div class="card-toolbar">
            <div class="d-flex justify-content-end" data-kt-user-table-toolbar="base">
                <a asp-action="Seasons" asp-controller="AdminGameWorld" class="btn btn-light-primary me-3">
                    <i class="ki-duotone ki-calendar fs-2"></i> Sezonları Yönet
                </a>
                <a asp-action="CreateGameWorld" asp-controller="AdminGameWorld" class="btn btn-primary">
                    <i class="ki-duotone ki-plus fs-2"></i> Yeni Dünya Ekle
                </a>
            </div>
        </div>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-bordered table-row-gray-100 align-middle gs-0 gy-3">
                <thead>
                    <tr class="fw-bolder text-muted">
                        <th class="w-50px">Sıra</th>
                        <th class="min-w-150px">Dünya Adı</th>
                        <th>Enerji Kuralları</th>
                        <th>Sezon Sayısı</th>
                        <th class="min-w-100px text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var item = Model[i];
                        <tr>
                            <td>
                                <span class="text-muted fw-bold">@(i + 1)</span>
                            </td>
                            <td>
                                <span class="text-dark fw-bolder text-hover-primary fs-6">@item.Name</span>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-muted fw-bold fs-7">Max: @item.MaxEnergy</span>
                                    <span class="text-muted fw-bold fs-7">Yenilenme: @item.RegenRatePerHour/saat</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-light-primary fs-7 fw-bold">@item.SeasonsCount Sezon</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="EditGameWorld" asp-controller="AdminGameWorld" asp-route-id="@item.Id" 
                                   class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1"
                                   data-bs-toggle="tooltip" title="Düzenle">
                                    <span class="svg-icon svg-icon-3">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <path opacity="0.3" d="M21.4 8.35303L19.241 10.511L13.485 4.755L15.643 2.59595C16.0248 2.21423 16.5426 1.99988 17.0825 1.99988C17.6224 1.99988 18.1402 2.21423 18.522 2.59595L21.4 5.474C21.7817 5.85581 21.9962 6.37355 21.9962 6.91345C21.9962 7.45335 21.7817 7.97122 21.4 8.35303ZM3.68699 21.932L9.88699 19.865L4.13099 14.109L2.06399 20.309C1.98815 20.5354 1.97703 20.7787 2.03189 21.0111C2.08674 21.2436 2.2054 21.4561 2.37449 21.6248C2.54359 21.7934 2.75641 21.9115 2.989 21.9658C3.22158 22.0201 3.4647 22.0084 3.69099 21.932H3.68699Z" fill="currentColor" />
                                            <path d="M5.574 21.3L3.692 21.928C3.46591 22.0032 3.22334 22.0141 2.99144 21.9594C2.75954 21.9046 2.54744 21.7864 2.3789 21.6179C2.21036 21.4495 2.09202 21.2375 2.03711 21.0056C1.9822 20.7737 1.99289 20.5312 2.06799 20.3051L2.696 18.422L5.574 21.3ZM4.13499 14.105L9.891 19.861L19.245 10.507L13.489 4.75098L4.13499 14.105Z" fill="currentColor" />
                                        </svg>
                                    </span>
                                </a>
                                <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm js-delete-btn" 
                                        data-id="@item.Id" data-name="@item.Name">
                                    <span class="svg-icon svg-icon-3">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <path d="M5 9C5 8.44772 5.44772 8 6 8H18C18.5523 8 19 8.44772 19 9V18C19 19.6569 17.6569 21 16 21H8C6.34315 21 5 19.6569 5 18V9Z" fill="currentColor" />
                                            <path opacity="0.5" d="M5 5C5 4.44772 5.44772 4 6 4H18C18.5523 4 19 4.44772 19 5V5C19 5.55228 18.5523 6 18 6H6C5.44772 6 5 5.55228 5 5V5Z" fill="currentColor" />
                                            <path opacity="0.5" d="M9 4C9 3.44772 9.44772 3 10 3H14C14.5523 3 15 3.44772 15 4V4H9V4Z" fill="currentColor" />
                                        </svg>
                                    </span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.js-delete-btn', function() {
            const id = $(this).data('id');
            const name = $(this).data('name');

            Swal.fire({
                title: 'Dünyayı Sil?',
                text: `${name} dünyasını ve bağlı tüm sezon verilerini silmek istediğinize emin misiniz?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                customClass: {
                    confirmButton: "btn btn-danger",
                    cancelButton: "btn btn-active-light"
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/AdminGameWorld/DeleteGameWorld',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Silindi!', 'Oyun dünyası başarıyla silindi.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Hata!', 'Silme işlemi sırasında bir hata oluştu.', 'error');
                            }
                        }
                    });
                }
            });
        });

        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        });
    </script>
}
