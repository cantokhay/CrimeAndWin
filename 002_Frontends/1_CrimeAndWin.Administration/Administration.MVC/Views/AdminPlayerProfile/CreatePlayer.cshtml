@model Administration.MVC.ViewModels.PlayerProfileVMs.PlayerVMs.CreatePlayerVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yeni Oyuncu Profili Olustur";
}

<!--begin::Toolbar-->
<div class="toolbar py-5 py-lg-15" id="kt_toolbar">
    <div id="kt_toolbar_container" class="container-xxl d-flex flex-stack flex-wrap">
        <div class="page-title d-flex flex-column me-3">
            <h1 class="d-flex text-white fw-bold my-1 fs-3">Yeni Profil Tanımla</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                <li class="breadcrumb-item text-white opacity-75">Oyun Yonetimi</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75 text-hover-primary">Oyuncular</li>
                <li class="breadcrumb-item"><span class="bullet bg-white opacity-75 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-white opacity-75">Yeni Oyuncu</li>
            </ul>
        </div>
    </div>
</div>
<!--end::Toolbar-->

<form asp-action="CreatePlayer" method="post">
    @Html.AntiForgeryToken()
    
    <div class="card card-flush shadow-sm border-0 mb-5">
        <div class="card-header pt-7">
            <h3 class="card-title fw-bold text-dark fs-3">Profil Detaylari</h3>
        </div>
        <div class="card-body pt-5">
            <div class="row g-9 mb-8">
                <div class="col-md-6 fv-row">
                    <label class="required fs-6 fw-bold mb-2 text-primary">Kullanıcı Secimi (AppUser)</label>
                    <input type="text" asp-for="AppUserId" class="form-select form-select-solid fw-bold" placeholder="AppUserId (Guid)" />
                    <span asp-validation-for="AppUserId" class="text-danger fs-8"></span>
                </div>
                <div class="col-md-6 fv-row">
                    <label class="required fs-6 fw-bold mb-2">Ekran Adı (DisplayName)</label>
                    <input type="text" asp-for="DisplayName" class="form-select form-select-solid fw-bold" />
                    <span asp-validation-for="DisplayName" class="text-danger fs-8"></span>
                </div>
            </div>

            <div class="row g-9 mb-8">
                <div class="col-md-3 fv-row">
                    <label class="fs-6 fw-bold mb-2 text-muted">Power</label>
                    <input type="number" asp-for="Power" class="form-select form-select-solid fw-bold" value="10" />
                </div>
                <div class="col-md-3 fv-row">
                    <label class="fs-6 fw-bold mb-2 text-muted">Defense</label>
                    <input type="number" asp-for="Defense" class="form-select form-select-solid fw-bold" value="10" />
                </div>
                <div class="col-md-3 fv-row">
                    <label class="fs-6 fw-bold mb-2 text-muted">Agility</label>
                    <input type="number" asp-for="Agility" class="form-select form-select-solid fw-bold" value="10" />
                </div>
                <div class="col-md-3 fv-row">
                    <label class="fs-6 fw-bold mb-2 text-muted">Luck</label>
                    <input type="number" asp-for="Luck" class="form-select form-select-solid fw-bold" value="5" />
                </div>
            </div>

            <div class="row g-9 mb-8 text-end">
                <div class="col-12">
                    <a asp-action="Players" class="btn btn-light-warning me-2 fw-bold">Listeye Don</a>
                    <button type="submit" class="btn btn-primary fw-bold">Profili Olustur</button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
