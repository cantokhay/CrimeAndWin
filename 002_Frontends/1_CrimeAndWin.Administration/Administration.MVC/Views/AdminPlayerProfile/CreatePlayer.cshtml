@model CreatePlayerVM

@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Yeni Player Oluştur</h3>

        <a asp-action="Players"
           asp-controller="AdminPlayerProfile"
           class="btn btn-sm btn-light">
            Listeye Dön
        </a>
    </div>
    <div class="card-body">
        <form asp-action="CreatePlayer"
              asp-controller="AdminPlayerProfile"
              method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Kullanıcı</label>
                    <select asp-for="AppUserId"
                            asp-items="Model.UserOptions"
                            class="form-select">
                        <option value="">Seçiniz...</option>
                    </select>
                    <span asp-validation-for="AppUserId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Display Name</label>
                    <input asp-for="DisplayName" class="form-control" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Avatar Key</label>
                    <input asp-for="AvatarKey" class="form-control" />
                    <span asp-validation-for="AvatarKey" class="text-danger"></span>
                </div>

                <!-- Stats -->
                <div class="col-12 mt-3">
                    <h5>Stats</h5>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Power</label>
                    <input asp-for="Power" class="form-control" type="number" />
                    <span asp-validation-for="Power" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Defense</label>
                    <input asp-for="Defense" class="form-control" type="number" />
                    <span asp-validation-for="Defense" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Agility</label>
                    <input asp-for="Agility" class="form-control" type="number" />
                    <span asp-validation-for="Agility" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Luck</label>
                    <input asp-for="Luck" class="form-control" type="number" />
                    <span asp-validation-for="Luck" class="text-danger"></span>
                </div>

                <!-- Energy -->
                <div class="col-12 mt-3">
                    <h5>Energy</h5>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Current</label>
                    <input asp-for="EnergyCurrent" class="form-control" type="number" />
                    <span asp-validation-for="EnergyCurrent" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Max</label>
                    <input asp-for="EnergyMax" class="form-control" type="number" />
                    <span asp-validation-for="EnergyMax" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Regen / dk</label>
                    <input asp-for="EnergyRegenPerMinute" class="form-control" type="number" />
                    <span asp-validation-for="EnergyRegenPerMinute" class="text-danger"></span>
                </div>

                <!-- Rank -->
                <div class="col-12 mt-3">
                    <h5>Rank</h5>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Rank Points</label>
                    <input asp-for="RankPoints" class="form-control" type="number" />
                    <span asp-validation-for="RankPoints" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Rank Position</label>
                    <input asp-for="RankPosition" class="form-control" type="number" />
                    <span asp-validation-for="RankPosition" class="text-danger"></span>
                </div>

                <div class="col-md-6 mt-3">
                    <label class="form-label">Last Energy Calc (UTC)</label>
                    <input asp-for="LastEnergyCalcUtc" class="form-control" type="datetime-local" />
                    <span asp-validation-for="LastEnergyCalcUtc" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Players"
                   asp-controller="AdminPlayerProfile"
                   class="btn btn-light ms-2">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}